@DOC ver=2.0 | id=orient-roadmap | title="/orient-roadmap" | kind=skill | profile=exec | fmt=min | guide="https://yon.younndai.com/yon-guide.txt"
@INTENT goal="Compute a fresh ephemeral read of the work's forward horizons — the increment arc built to current to next, what shipped now, the gates, the next increment's clusters with the paramount one starred, and the runway of stage boxes now to gated-next to future plus the deferred lanes — via a bounded read-only subagent. Own the horizon fields for the family. Emit the roadmap slice of a record conformant to references/orient-spec/orient-record.yon." | audience=agent
@STAMP ts:ts=2026-07-19T00:00:00Z | src="Alexandru Mares | allemaar.com" | method=generated
@NOTE text="Emits the roadmap slice of the shared orientation record (references/orient-spec/orient-record.yon): the envelope @CFG id=orient, @CFG id=subject (carries parent_subject for the breadcrumb and intent_status), @CFG id=roadmap, increment nodes as @CFG id=node.<x> with kind=increment (a free str) and an istatus carrying the increment_status enum, the arrows between them as @MAP name=edges; the list fields (built_items gates next_items runway_stages cleanup_now deferred) as sidecar @MAP; per-field provenance as @MAP. The star paramount marker and the deferred dot ride inside the item label as render hints, never as new tier glyphs. Reserved tags only; validate --profile exec then the value gate references/tools/orient-validate.mjs; never run yon format on an instance. Two orthogonal axes: the tier axis (◆◐◌ provenance, the a11y non-color encoding) and the state/role axis (the handler emoji ✅◉🔄★▢◌⚠ in the markdown/ascii face, translated to shape-glyphs in the widget). Enum membership and these @RULE/@CHECK gates are emitter obligations enforced pre-emit by the value gate references/tools/orient-validate.mjs (enum membership plus the fail-closed cross-field gate), which yon validate --profile exec does not check."

@SEC name="Inputs"
@INPUT rid=in:scope | name="scope" | type=artifact | required:bool=true
@INPUT rid=in:intent | name="intent" | type=artifact | required:bool=false
@INPUT rid=in:anchor | name="anchor" | type=artifact | required:bool=false

@SEC name="Rules"
@RULE rid=rule:horizon-first | lvl=MUST | when="rendering the bundle" | then="lead with the forward increment arc and the runway because the retrospective delta belongs to orient-map and the node you stand on belongs to orient-status"
@RULE rid=rule:budget-arc-runway | lvl=MUST | when="rendering the increment arc and the runway" | then="hold the arc to at most three increment nodes with exactly one current the hero and the runway to at most three stage boxes now and gated-next and future, and decompose into an overview arc plus a drill-down runway rather than cram when a live emission exceeds that"
@RULE rid=rule:horizon-authority | lvl=MUST | when="emitting the roadmap slice" | then="own and emit arc_current and arc_idx and arc_count and paramount_ref and now_count and next_count and runway_span and cleanup_now_count and deferred_count so sibling slices do not recompute the horizons"
@RULE rid=rule:two-axes | lvl=MUST | when="encoding state and provenance" | then="keep the tier axis of attested and inferred and guessed separate from the state-role axis of the handler emoji, and treat the star as a paramount role marker on a next-item chip never as a tier glyph because the ratified tier glyph rides only the trust trailer in a different render zone"
@RULE rid=rule:intent-gates | lvl=MUST | when="intent or the north-star is absent or ungrounded" | then="gate every intent-dependent horizon as needs-goal and cap its provenance tier to guessed, and never emit a confident runway from the void"
@RULE rid=rule:fail-closed | lvl=MUST | when="evidence is zero or barren" | then="set gate_status to degraded or indeterminate with a sentinel value and draw a no-substrate card rather than a plausible verdict or a structural roadmap"
@RULE rid=rule:trust-trailer | lvl=MUST | when="emitting the markdown read" | then="end with the trust trailer naming the single load-bearing guess on a lean-here line plus the one-line legend, and keep the deferred word on deferred items so the widget dashed chips have a text twin"
@RULE rid=rule:ephemeral | lvl=MUST | when="emitting any record" | then="set ephemeral true and a fresh computed_at, persist no derived snapshot, and rely on a caller-supplied or git-inferred anchor never written to disk"
@RULE rid=rule:bounded-sweep | lvl=MUST | when="gathering evidence" | then="delegate to one read-only depth-1 subagent with a budget and a hard timeout and a stop-condition, and return only the bundle with a re-runnable proof on every attested field"
@RULE rid=rule:list-encoding | lvl=MUST | when="emitting a list field" | then="emit built_items and gates and next_items and runway_stages and cleanup_now and deferred and edges as sidecar @MAP and increment nodes as @CFG id=node.x, and never a bare bracket-list inside a set and never run yon format on the instance"
@RULE rid=rule:footer-installed | lvl=MUST | when="the family footer suggests a next skill" | then="suggest only an installed skill and otherwise fall back to a prose hint or orient-status or plan-create"
@RULE rid=rule:render-face | lvl=MUST | when="choosing the visual face" | then="render per the orient-spec render-face contract: an agent consumer gets the yon record only, a human on claude-code with the visualize tool present on an explicit invocation gets the widget plus the ascii twin, an auto-loop nominal read collapses to one line, any other runtime or no tool gets the ascii twin, and an indeterminate handler_type fails closed to the ascii twin; the widget is claude-code-only via mcp__visualize__show_widget built from the kit after calling mcp__visualize__read_me once; the yon record is the agent face only and MUST NOT be printed into a human-facing reply, and no raw record field or node-id or gate enum or @CFG line or @MAP line reaches the human, who receives the plain-language read plus the visual"
@RULE rid=rule:widget-parity | lvl=MUST | when="emitting a widget" | then="the widget and the ascii twin are projections of one node-structure carrying the same increment and item and gate and stage and lane labels and the diamond tier glyphs as redundant non-color encoding, the roadmap widget is an eight-band board with each band an independent g transform group and the current increment the dominant node and deferred chips dashed and faded and no emoji in the widget face, and it obeys the chrome rules of no hardcoded color and no position-fixed and role-img with non-empty title and desc and the fixed 780 viewBox, all checked by the repository-only tools/orient-roundtrip.mjs release guard when running from a clone; installed copies retain this as an emitter obligation"

@SEC name="Steps"
@STEP rid=step:bind-intent | n:int=1 | op=std:data.transform@v1 | args=[task="Bind the intent or north-star and the anchor inputs and set intent_status and anchor_kind. Infer the anchor from git or a PLAN.md when not supplied and never write it to disk. Do not prompt the caller."] | in=[rid:in:intent,rid:in:anchor] | out=[ref:intent-bound]
@STEP rid=step:sweep | n:int=2 | op=std:data.search@v1 | args=[task="Spawn one bounded read-only depth-1 subagent over scope using the cheap-first ladder git then plan then conversation; read the built items from git log and merged work, the current frontier, and from a PLAN.md or roadmap the increment arc and the gates and the next increment's clusters and which is paramount and the runway stages now and gated-next and future and the deferred lanes; budget 8 to 12 calls, timeout 60 to 90 seconds, stop at the first confident tier; return only signal with proof per the SKILL.md return fields."] | in=[rid:in:scope,ref:intent-bound] | out=[ref:evidence]
@STEP rid=step:build-roadmap | n:int=3 | op=std:data.transform@v1 | args=[task="Build the roadmap slice from the evidence: the increment arc as a three-node spine with one istatus current the hero, the built_items and gates and next_items with the paramount one starred and runway_stages and cleanup_now and deferred maps; hold the arc to at most three nodes and the runway to at most three stages and decompose rather than cram beyond that; set arc_current and arc_idx and arc_count and now_count and next_count and runway_span and paramount_ref and cleanup_now_count and deferred_count; tag every field with a provenance tier and gate intent-dependent horizons when intent-status is absent."] | in=[ref:evidence,ref:intent-bound] | out=[ref:record]
@STEP rid=step:emit | n:int=4 | op=std:io.emit@v1 | args=[surface="caller",task="Route the bundle by consumer: an agent consumer receives the yon record, a human consumer receives the plain-language markdown read plus the visual and never the record nor any raw record field nor node-id nor gate enum. Build the record conformant to orient-record for the agent face: the @CFG id=orient envelope, @CFG id=subject identity with parent_subject when present, the roadmap slice, increment nodes as @CFG id=node.x with kind=increment and an istatus, the edges map, the list fields as sidecar @MAP, per-field provenance @MAP, the markdown read with the horizon board and the trust trailer and the one-line legend. Render the visual face per rule:render-face: for a human on claude-code with the visualize tool present on an explicit invocation, call mcp__visualize__read_me once then emit via mcp__visualize__show_widget a hand-SVG eight-band roadmap board on the fixed 780 viewBox with each band an independent g transform group and the current increment as the dominant node and the diamond tier glyphs as redundant non-color encoding and deferred chips dashed and faded and no emoji in the widget face; an agent consumer gets the yon record only; any other runtime or no tool or an indeterminate handler_type gets the ascii twin. Always emit the information-complete ASCII roadmap twin per rule:widget-parity (worked trio at references/orient-spec/examples/orient-roadmap.ascii.txt and orient-roadmap.widget.svg). Close with the installed-only family footer."] | in=[ref:record] | out=[ref:bundle] | rules=[rid:rule:render-face,rid:rule:widget-parity]

@SEC name="Gates"
@CHECK rid=chk:scope | assert="rid:in:scope != null" | fail=ABORT | msg="No scope to map — name the project, repo, folder, or task."
@CHECK rid=chk:budget | assert="the increment arc has at most three nodes and the runway at most three stages or the emission is decomposed" | fail=WARN | msg="The arc or runway exceeds the per-sub-graph budget — decompose into an overview arc plus a drill-down runway rather than cram."
@CHECK rid=chk:fail-closed | assert="evidence is not barren or gate_status is degraded or indeterminate" | fail=ABORT | msg="Barren evidence must fail closed with a no-substrate card, never a plausible roadmap."
@CHECK rid=chk:value-gate | assert="references/tools/orient-validate.mjs accepts the emitted instance (every enum value is in range and the fail-closed cross-field gate holds)" | fail=ABORT | msg="Emitted record failed the orient value gate — an enum value is out of range or a barren read claims a verdict; fix before emit."

@SEC name="Next skills"
@STEP rid=step:nsp | n:int=99 | op=std:ai.prompt@v1 | args=[task="Run the Next Skills protocol: surface the next-skills front-matter recommendations for the caller to pick. Offer only and never auto-invoke."] | in=[] | out=[ref:nsp-offer]

@SEC name="Self-improvement"
@STEP rid=step:sip | n:int=100 | op=std:ai.prompt@v1 | args=[task="Run the Self-Improvement Protocol: if this run surfaced a concrete blocking-or-recurring weakness in this skill, propose a specific fix via ask-gate for handler approval. Conservative, silent otherwise, never auto-apply."] | in=[] | out=[ref:sip-offer]

