@DOC ver=2.0 | id=handoff-execute | title="Handoff-Execute — Receiving-Session Executor with Gated Source Ingestion" | kind=skill | profile=exec | fmt=min | guide="https://yon.younndai.com/yon-guide.txt"
@INTENT goal="Execute a handoff brief end-to-end with enforced source-read discipline before planning, a premise pre-flight that halts on already-shipped/stale-baseline work, source-cited plan steps, acceptance-coverage check, and a ground-truth retro with per-clause gate status. Phase 2 source-loaded gate and premise gate both abort in gated mode (unless --force is set); downgrade to WARN in advisory mode and under --force. Phase 3 coverage check is WARN-level — surfaces gaps for caller review without arbitrary aborts on single-sentence acceptance." | trigger="user runs /handoff-execute [--force] <brief-path>, or pastes the activation phrase emitted by /handoff"
@STAMP ts:ts=2026-06-04T18:00:00Z | src=human | method=manual

# --- Boundary ---

@SEC name="Boundary"
@RULE rid=rule:handoff-briefs-only | lvl=MUST | when="invoked" | then="consume only handoff briefs (YAML frontmatter type:handoff plus YON body blocks) — do not consume PLAN.md or other formats"
@RULE rid=rule:not-self-gate | lvl=MUST_NOT | when="target is a post-execution self-gate" | then="run handoff-execute — use /verify instead"
@MAP name=SiblingBoundary | pairs=["plan-execute"->"executes PLAN.md or implementation_plan.md (different schema, no source gate, no retro)","verify"->"post-execution self-gate checking intent/plan/execution alignment","cold-review"->"outside-agent review of completed work artifacts","double-check"->"re-verify one specific claim or output","handoff"->"creates the brief that handoff-execute consumes"]
@NOTE text="handoff-execute is the only skill that consumes a handoff brief and produces the canonical retro file at Handoffs/{project}/retros/{date}-{slug}-retro.md."

# --- Phase 1: Brief ingest ---

@SEC name="Phase 1 — Brief ingest"
@STEP rid=step:ingest | n:int=1 | op=std:ai.prompt@v1 | args=[task="Read the brief file in full. Parse YAML frontmatter — validate type:handoff or abort. Locate YON blocks in body: @TASK, @OUTCOME, @SCOPE (if present), @SOURCES (if present), @GROUND_TRUTH_REQUIRED, plus profile-specific blocks (@SUBTASKS for orchestrator, @CONTINUATION for new-session). Emit one-line confirmation: 'Brief loaded: <slug> · profile=<p> · required-sources=<N>'."] | in=[file:brief-path] | out=[ref:brief]
@CHECK rid=check:brief-valid | assert="brief frontmatter type field equals 'handoff'" | fail=ABORT | msg="Not a handoff brief — type field missing or wrong. Pass a /handoff-generated brief path."

# --- Phase 2: Source ingestion ---

@SEC name="Phase 2 — Source ingestion"
@MAP rid=map:source-tiers | pairs=["required"->"read fully before planning; ABORT-on-fail in gated mode, WARN-on-fail in advisory mode","optional"->"surfaced in checklist; read on-demand mid-execution if a step touches them; no gate"]
@MAP rid=map:execution-mode | pairs=["gated"->"brief has @SOURCES.required OR legacy @SCOPE.must_read OR an explicit markdown heading whose text (case-insensitive) is/contains Read-first, Read these first, or locked inputs, AND whose CLEANLY-ENUMERABLE entries (numbered/bulleted lines bearing a path or wikilink) form the required tier — Phase 2 gate is ABORT-on-fail unless --force flag is set; a prose-only such section with no enumerable entries degrades to WARN (see step:mode)","gated-forced"->"gated mode invoked with --force — Phase 2 gate downgrades to WARN; degraded-mode banner emitted; @SOURCE_FAILURES still recorded in retro","advisory"->"brief has NONE of the three gated triggers — Phase 2 gate downgrades to WARN; emit prominent warning that no source-read gate is enforced"]
@STEP rid=step:mode | n:int=2 | op=std:ai.prompt@v1 | args=[task="Determine execution mode per map:execution-mode. REQUIRED-tier precedence: (1) @SOURCES.required; else (2) legacy @SCOPE.must_read; else (3) an explicit markdown HEADING LINE (a line starting with one-to-six # chars) whose text contains, case-insensitively, Read-first / Read first / Read these first / locked inputs — a REAL heading only; ignore the phrase when it appears inside a fenced code block, a blockquote, or an example. Extract that section's required entries as the numbered/bulleted lines under the heading that bear a file path or a wikilink; lines tagged (optional) go to the optional tier. HYBRID severity: if (3) yields at least one cleanly-enumerable entry, treat it as GATED (read fully + ABORT-on-fail, same as 1 and 2); if the section is prose-only with no enumerable entries, fall to WARN (cannot gate on nothing) and continue. Many briefs (e.g. Watson's LYT briefs) declare locked inputs via this markdown section rather than a YON block. Only if NONE of (1)-(3) is present is mode advisory — then scan the body for wikilinks and absolute paths as a best-effort WARN-only source list."] | in=[ref:brief] | use=[cfg:map:execution-mode] | out=[ref:mode,ref:required-sources,ref:optional-sources]
@STEP rid=step:load-required | n:int=3 | op=std:ai.prompt@v1 | args=[task="For each entry in ref:required-sources, read the file fully via the runtime's read tool. For wikilinks, resolve to absolute vault path. For each successful read, compare file mtime to brief.created — emit non-blocking drift warning if newer. For each failure, run basename search across parent project and vault, surface top candidate as 'Did you mean?' suggestion (do not auto-resolve). Emit checklist with [✓] reads, [✗] failures, line counts."] | in=[ref:required-sources,ref:brief] | out=[ref:source-checklist,ref:source-failures]
@CHECK rid=check:sources-loaded | assert="if mode=gated AND --force is not set, ref:source-failures is empty" | fail=ABORT | msg="One or more @SOURCES.required entries failed to read in gated mode. Halt and write verdict:blocked retro with @SOURCE_FAILURES + @RESUME_HINT blocks. Surface recovery prompt to runtime user: amend the brief and re-invoke, or re-invoke with --force to proceed in degraded mode."
@CHECK rid=check:advisory-warning | assert="if mode=advisory OR mode=gated-forced, a prominent warning banner has been emitted before any plan text" | fail=WARN | msg="Advisory mode and gated-forced mode require a prominent warning so the cold agent and observer know no source-read gate is enforced."
@CATCH target=step:load-required | on="mode=gated AND --force is not set AND target is in ref:required-sources AND read failed" | do="emit @SOURCE_FAILURES block plus @RESUME_HINT block (specific paths to amend or rename), write verdict:blocked retro per Phase 5, surface one-line recovery prompt with --force re-invocation, abort skill — do not proceed to planning"
@STEP rid=step:premise-preflight | n:int=4 | op=std:ai.prompt@v1 | args=[task="Reconcile the brief's stated premises against the live repo before planning (per-source existence is already covered by step:load-required; this checks premises). (a) Git state — is this already done? Run git log/git status over the brief scope paths; if commits matching the task (message, touched-file set, or a SHA the brief names) already landed, the work may be done — strongest drift signal, halt. (b) Cited baselines — check any concrete number the brief states (test count, schema version, op count) against the current tree. (c) Structural claims — verify a package it says to create doesn't already exist and a file it says is missing is actually missing. Emit a premise checklist (stated -> actual per premise). Distinguish already-shipped (brief obsolete — stop) from baseline-drift (surface, let runtime user decide)."] | in=[ref:brief,ref:source-checklist] | out=[ref:premise-report,ref:premise-drift]
@CHECK rid=check:premise-intact | assert="if mode=gated AND --force is not set, no brief premise is stale — work is not already shipped, cited test/schema baselines match the tree, and structural claims hold" | fail=ABORT | msg="Brief premise is stale. Halt and write verdict:blocked retro with @PREMISE_DRIFT (stated vs actual per premise) + @RESUME_HINT. Distinguish already-shipped (brief obsolete — stop) from baseline-drift (surface). --force downgrades to WARN."
@CATCH target=step:premise-preflight | on="mode=gated AND --force is not set AND a brief premise is stale (already-shipped OR baseline-drift OR structural mismatch)" | do="emit @PREMISE_DRIFT block (stated vs actual per premise) plus @RESUME_HINT, write verdict:blocked retro per Phase 5, surface the already-shipped vs baseline-drift distinction, abort skill — do not proceed to planning"
@STEP rid=step:verify-cmd-resolvable | n:num=4.5 | op=std:ai.prompt@v1 | args=[task="Statically reconcile the brief's stated verify/spot-check commands (frontmatter verify: field + any regenerate-and-grep / spot-check command in the body) against the live repo BEFORE planning, WITHOUT running side-effectful commands. For each command, confirm the named binary/script/dist path exists, and for a CLI subcommand confirm it resolves (a side-effect-free `--help` probe is allowed; NEVER run the full verify command here — it may mutate). On an 'unknown command' / 'no such file' / 'command not found' resolution failure, emit a WARN with a 'did you mean?' hint (basename / sibling search) and surface the corrected command so Phase 4/5 run the right one. Do NOT abort — the brief's TASK is still executable; only its verify command is mis-pathed."] | in=[ref:brief] | out=[ref:verify-cmd-report]
@CHECK rid=check:verify-cmd-resolvable | assert="each brief-stated verify/spot-check command resolves to an existing binary/subcommand, OR a WARN with a corrected-path hint was emitted" | fail=WARN | msg="A brief-stated verify command does not resolve (e.g. names the wrong CLI/dist path). Surface the mismatch + corrected command now so execution + Phase-5 verify use the right one; do not abort — the task itself is still executable."

# --- Phase 3: Plan ---

@SEC name="Phase 3 — Plan"
@STEP rid=step:plan | n:int=5 | op=std:ai.prompt@v1 | args=[task="Produce a numbered plan. Each step maps to (a) the @OUTCOME.acceptance sub-criterion it addresses and (b) the source(s) supporting it (file:line where possible). Format: '<n>. <action> → acceptance: <fragment> · source: <ref>'. Plan must cover every acceptance sub-criterion."] | in=[ref:brief,ref:source-checklist] | out=[ref:plan]
@CHECK rid=check:plan-cites-sources | assert="every plan step cites at least one source" | fail=WARN | msg="Plan step is uncited. Pure tooling/setup steps may be unsourced — flag and continue. Verify steps cover the actual work substance."
@CHECK rid=check:plan-covers-acceptance | assert="cold agent has reasoned over @OUTCOME.acceptance clauses and flagged any clause not addressed by at least one plan step" | fail=WARN | msg="Acceptance is a single sentence; clause segmentation is fallible. Flag uncovered clauses for caller review explicitly in plan emission (do not silently leave gaps). For rigorous coverage, brief authors can rewrite acceptance as semicolon-delimited clauses to give the cold agent explicit segmentation."

# --- Phase 4: Execute ---

@SEC name="Phase 4 — Execute"
@STEP rid=step:execute | n:int=6 | op=std:ai.prompt@v1 | args=[task="Run each plan step in order. On-demand @SOURCES.optional reads are citation-driven: a step triggers a load only if it names a ref:optional-sources entry in its '· source:' clause from Phase 3. Cold agent does not decide ad-hoc to read optional sources. If mid-execution the cold agent discovers a needed source not in the plan, halt and surface the gap rather than silently expanding scope. Capture per-step: artifacts modified (paths + hashes), command outputs, observations. If a step fails, do not retry — proceed to Phase 5 with verdict:partial."] | in=[ref:plan,ref:optional-sources] | out=[ref:execution-log,ref:artifacts]
@RULE rid=rule:no-silent-retry | lvl=MUST_NOT | when="a plan step fails during execution" | then="silently retry — emit a partial retro instead"
@RULE rid=rule:on-demand-optional | lvl=SHOULD | when="a plan step's source citation names a @SOURCES.optional entry" | then="read the specific cited section on-demand before acting; do not load optional sources outside of plan-step citations"
@RULE rid=rule:no-scope-expansion | lvl=MUST_NOT | when="mid-execution discovers a needed source not in the brief" | then="silently expand scope — halt and surface the gap; the brief must be amended"

# --- Phase 5: Verify + retro ---

@SEC name="Phase 5 — Verify + retro"
@STEP rid=step:verify | n:int=7 | op=std:ai.prompt@v1 | args=[task="Run every command in @OUTCOME.verify (the brief's frontmatter verify: field). Compare results to the acceptance sentence. If the work produced committable code, also run the project's defined gate suite (lint/test/typecheck — e.g. turbo run lint test typecheck where present) as a deliberate pre-commit gate, not a speculative auto-run. Map each acceptance clause to the specific verification that exercised it: per clause -> verified|unverified|failed, plus the gate-suite outcome (pass|fail|skipped — why). Capture verify-command outputs for the retro."] | in=[ref:brief,ref:artifacts] | out=[ref:verify-results,ref:gate-status]
@STEP rid=step:retro | n:int=8 | op=std:ai.prompt@v1 | args=[task="Write the retro file to Handoffs/{project}/retros/{date}-{slug}-retro.md (or the brief's output_location override if present) per the schema in ../handoff/SKILL.md (Retro schema section). Mandatory YON blocks: @OUTCOME_DELIVERED, @GROUND_TRUTH (artifacts_modified paths+hashes, git_diff_summary), @GATE_STATUS (per-clause verified|unverified|failed + gate-suite outcome; name skipped gates and unverified clauses, never silently omit), @DELTA_FROM_BRIEF, @RECOMMENDATIONS, @VERDICT. For a blocked premise pre-flight, include @PREMISE_DRIFT (stated vs actual per premise) instead. Also emit the retro as a chat block — full if <500 lines, else summary plus path. If write fails (path missing, permission denied, disk full): still emit the retro to chat, append @WRITE_FAILURE block:bool=true | reason='...' | attempted_path='...', set @VERDICT to partial even if execution was clean — do not silently exit, do not retry."] | in=[ref:brief,ref:execution-log,ref:artifacts,ref:verify-results,ref:gate-status,ref:premise-drift,ref:source-failures] | out=[file:retro-path]
@CHECK rid=check:retro-has-ground-truth | assert="retro contains @GROUND_TRUTH with non-empty artifacts_modified and git_diff_summary" | fail=ABORT | msg="Retro is narrative-only — paths, hashes, and git diff are required by @GROUND_TRUTH_REQUIRED in the brief. Re-emit with ground truth."
@CHECK rid=check:retro-write-fallback | assert="if vault write failed, retro was still emitted to chat AND @WRITE_FAILURE block is present AND verdict is partial" | fail=WARN | msg="Vault write failure must not cause silent retro loss. Chat-emit + @WRITE_FAILURE + partial verdict is the fallback contract."
@RULE rid=rule:retro-canonical | lvl=MUST | when="completing execution" | then="write the retro file to the canonical vault path AND emit as chat block — file is canonical, chat is paste-convenience for second-assessment"
@RULE rid=rule:retro-write-failure | lvl=MUST | when="vault write fails" | then="emit retro to chat with @WRITE_FAILURE block, set verdict to partial, do not silently exit, do not retry"

# --- Rules (collected) ---

@SEC name="Rules"
@RULE rid=rule:read-required-before-plan | lvl=MUST | when="mode=gated" | then="read all @SOURCES.required entries fully before any plan text is emitted; abort with verdict:blocked retro on failure"
@RULE rid=rule:premise-preflight | lvl=MUST | when="before emitting any plan" | then="reconcile brief premises against the live repo (git state for already-shipped work, cited test/schema baselines, structural claims); halt with verdict:blocked @PREMISE_DRIFT retro if a premise is stale, downgraded to WARN under --force"
@RULE rid=rule:verify-cmd-preflight | lvl=SHOULD | when="the brief states verify/spot-check commands" | then="statically reconcile each against the repo before planning (named path exists; CLI subcommand resolves via a side-effect-free --help probe; never run the full verify here); WARN + surface a corrected command on an unknown-command / no-such-file mismatch, never abort — the task is still executable, only its verify command is mis-pathed"
@RULE rid=rule:cover-acceptance | lvl=MUST | when="emitting plan" | then="map every @OUTCOME.acceptance sub-criterion to at least one plan step"
@RULE rid=rule:gate-status | lvl=SHOULD | when="work is committable code" | then="run the project's defined gate suite before declaring done and record @GATE_STATUS in the retro (per-clause verified|unverified|failed + gate-suite outcome); name skipped gates and unverified clauses, never silently omit"
@RULE rid=rule:retro-ground-truth | lvl=MUST | when="writing retro" | then="include @GROUND_TRUTH with artifacts_modified paths plus hashes plus git_diff_summary — narrative-only retros are rejected"
@RULE rid=rule:cite-sources | lvl=SHOULD | when="emitting a plan step" | then="cite at least one source (file:line where possible)"
@RULE rid=rule:no-invented-sources | lvl=MUST_NOT | when="a needed source is missing from the brief" | then="invent or assume sources — halt and request brief amendment"
@RULE rid=rule:no-auto-resolve | lvl=MUST_NOT | when="a @SOURCES.required entry fails to read" | then="auto-resolve by picking the closest filename match — surface the suggestion only"

# --- Next Skills ---

@SEC name="Next Skills"
@STEP rid=step:nsp | n:int=9 | op=std:ai.prompt@v1 | args=[task="Run the Next Skills protocol (next-skills/protocol.yon): surface the front-matter next-skills recommendations (/insight-critique to second-assess the retro; /github-sync to commit the work) for the caller to pick. Offer only — never auto-invoke."] | in=[file:retro-path] | out=[ref:nsp-offer]

# --- Self-improvement ---

@SEC name="Self-improvement"
@STEP rid=step:sip | n:int=10 | op=std:ai.prompt@v1 | args=[task="Run the Self-Improvement Protocol (self-improve/protocol.yon): if this run surfaced a concrete, blocking-or-recurring weakness in THIS skill (ambiguity, uncovered edge case, forced deviation, misfired gate, stale cross-reference, user correction), draft a specific diff and surface it via /ask-gate for handler approval. Conservative — silent otherwise; dedup against already-proposed; never auto-apply."] | in=[] | out=[ref:sip-offer]

@STAMP ts:ts=2026-06-09T00:00:00Z | src="agent:claude-code" | method=manual | note="Added step:verify-cmd-resolvable + check + rule:verify-cmd-preflight (Phase 2 verify-command resolvability WARN) via SIP after V-DOC-1; SKILL.md kept in sync."
