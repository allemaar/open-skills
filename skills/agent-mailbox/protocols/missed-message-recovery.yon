@DOC ver=2.0 | id=agent-mailbox-missed-message-recovery | title="Agent Mailbox Missed Message Recovery" | kind=workflow | profile=exec | fmt=min | classification=public | guide="https://yon.younndai.com/yon-guide.txt" | parent=agent-mailbox
@INTENT goal="Recover from a reported message miss or incomplete consumed-UUID cursor without repeating external effects, treating peer activity as proof of local consumption, or restoring readiness before a real end-to-end check"
@STAMP ts:ts=2026-07-23T00:00:00Z | src="Alexandru Mares | allemaar.com" | method=merged

@SEC name="Package contract"
@NOTE text="Package id missed-message-recovery version 1; compatible with Agent Mailbox base 1.x; mandatory trigger-loaded overlay for a reported miss, cursor inconsistency, or readiness contradiction"
@MAP rid=map:recovery-dispositions | name=RecoveryDispositions | pairs=["handled"->"the current effective disposition is terminal","transitional"->"blocked by Handler-decision deferred or needs-audit remains open and does not advance the cursor","legacy-mode-advisory"->"sender-local legacy mode metadata handled once by the bounded compatibility rule and never negotiated","historical-debt"->"quarantined history must not be executed again automatically and remains readiness-blocking","reconstructable-response"->"an exact locally authored causal ack reply or response proves the prior local outcome","effect-evidenced"->"exact independently verified effect or idempotency evidence tied to the inbound request proves the external effect already completed","needs-audit"->"a prior effect cannot be proved or excluded; quarantine instead of executing","unconsumed"->"no current disposition causal outcome or prior-effect evidence exists; route through the normal authority gate"]
@RULE rid=rule:degrade-first | lvl=MUST | when="a message miss cursor inconsistency or readiness contradiction is reported" | then="revoke LISTENING immediately, record DEGRADED cursor-incomplete or the specific failure, and load this package before re-arming"
@RULE rid=rule:stop-before-audit | lvl=MUST | when="starting recovery" | then="stop the nonconforming owned listener or scheduled job and verify its process tree or native job identity is gone before auditing state"
@RULE rid=rule:disposition-authority | lvl=MUST | when="deciding whether an inbound UUID was handled" | then="treat the durable per-message disposition as authoritative and the consumed-UUID cursor as a compact checkpoint or index only"
@RULE rid=rule:exact-local-reconstruction | lvl=MUST | when="the cursor omits a UUID but an exact locally authored causal ack reply or response exists with matching reply_to and request_id" | then="reconstruct only the missing disposition and cursor bookkeeping from that evidence and never repeat the external effect"
@RULE rid=rule:exact-effect-reconstruction | lvl=MUST | when="a cursor omission has no disposition or locally authored causal response but exact independently verified effect or idempotency evidence tied to the inbound UUID request_id or recorded idempotency key proves the external effect completed" | then="reconstruct the acted disposition and missing bookkeeping, complete only an owed causal status reply, and never repeat the external effect"
@RULE rid=rule:peer-descendant-not-proof | lvl=MUST_NOT | when="only a peer-authored descendant or later thread activity references the inbound message" | then="treat that activity as proof the local participant consumed or handled the message"
@RULE rid=rule:no-reply-not-proof | lvl=MUST_NOT | when="an inbound envelope says expects_reply false" | then="infer local consumption without a durable no-reply-required or other explicit disposition"
@RULE rid=rule:quarantine-ambiguity | lvl=MUST | when="history lacks an authoritative disposition or exact locally authored causal outcome" | then="record historical-debt or needs-audit, preserve active authorized work, and do not repeat an external effect automatically"
@RULE rid=rule:missing-ledger-degrades | lvl=MUST | when="the participant-local disposition ledger is unavailable at the current owner arena and mailbox root and no explicit Handler-authorized private transfer exists" | then="record DEGRADED disposition-unavailable, reconcile shared causal evidence without treating it as authoritative local state, quarantine ambiguity as historical-debt or needs-audit, and do not claim LISTENING"
@RULE rid=rule:filters-prioritize-only | lvl=MUST_NOT | when="an active request thread or reply_to filter is used" | then="erase or mark resolved any other valid addressed message or historical reconciliation debt"
@RULE rid=rule:conversation-isolation | lvl=MUST | when="a returning holder begins new work in an established room that contains prior protocol messages" | then="rehydrate with resume then state, preserve old conversation heads as history, preserve unresolved non-mode CTAs as separate debt, and begin new work only from a fresh ordinary CTA root with new thread and request-id UUIDv7 values"
@RULE rid=rule:legacy-mode-compatibility | lvl=MUST | when="inventory contains a legacy listener Work-or-Listen or scheduled-mode proposal" | then="classify it as sender-local advisory metadata; if it expects reply send at most one causal state compatibility notice per sender and legacy protocol generation with expects_reply false, otherwise record no-reply-required; never accept counter renew or wait on it"
@RULE rid=rule:fresh-proof-before-listening | lvl=MUST | when="recovery is complete enough to consider readiness" | then="process one fresh real addressed message through detection, validation, durable disposition, cursor checkpoint, heartbeat, and runtime wake or re-entry before restoring LISTENING"

@SEC name="Execution"
@STEP rid=step:recovery-freeze | n:int=1 | op=std:cmd.run@v1 | args=[task="Record the failure, set DEGRADED, stop the owned listener or scheduled job, verify descendants or the native job are gone, and preserve logs and exact local evidence privately. Do not delete peer messages or ambiguous history."] | out=[ref:recovery-frozen]
@CHECK rid=check:recovery-stopped | assert="the nonconforming owned listener or job is absent and no claim of LISTENING remains" | fail=ABORT | msg="Recovery cannot audit against a still-running nonconforming consumer."
@STEP rid=step:recovery-reconcile | n:int=2 | op=std:ai.prompt@v1 | in=[ref:recovery-frozen] | use=[cfg:map:recovery-dispositions] | args=[task="Run the transport correctness sync, parse every inbox message, and select every valid message addressed to the local participant. Reconcile each UUID against the authoritative disposition ledger and compact cursor only when the participant-local state has an exact owner arena and mailbox-root match or an explicit Handler-authorized private transfer. Otherwise record DEGRADED disposition-unavailable and quarantine ambiguous shared evidence. Active filters may order work but never remove candidates or debt."] | out=[ref:recovery-inventory]
@STEP rid=step:recovery-classify | n:int=3 | op=std:ai.prompt@v1 | in=[ref:recovery-inventory] | args=[task="Classify each cursor omission from the current effective disposition and exact evidence in this order: handled only for a terminal effective state; transitional for blocked by Handler-decision deferred or needs-audit; legacy-mode-advisory under rule:legacy-mode-compatibility; historical-debt for quarantined history; reconstructable-response only from an exact locally authored causal ack reply or response with matching reply_to and request_id; effect-evidenced only from exact independently verified effect or idempotency evidence tied to the inbound UUID request_id or recorded idempotency key; needs-audit when a prior effect cannot be proved or excluded; genuinely unconsumed only when no disposition causal outcome or prior-effect evidence exists. Peer-authored descendants and expects_reply false never prove local consumption."] | out=[ref:recovery-classification]
@CHECK rid=check:effect-state-decided | assert="every cursor omission was classified after inspecting current effective disposition exact causal evidence and exact prior-effect evidence; no item enters normal execution when a prior effect cannot be excluded" | fail=ABORT | msg="Prior effect state is unresolved. Quarantine as needs-audit; do not route to normal execution."
@STEP rid=step:recovery-repair | n:int=4 | op=std:fs.write@v1 | in=[ref:recovery-classification] | args=[task="For handled terminal items, restore only a missing cursor checkpoint. For transitional items, preserve their routing obligation and do not advance the cursor. For legacy-mode-advisory items, inspect exact local history for a prior compatibility state from this participant to that sender and protocol generation: if the inbound expects reply and no such state exists, send exactly one causal state with expects_reply false and append replied; otherwise emit no wire output and append no-reply-required. Advance the cursor for that terminal disposition and never accept counter renew or wait on the mode. For reconstructable-response items, write only missing disposition and cursor bookkeeping from exact local causal evidence. For effect-evidenced items, append acted and missing bookkeeping from exact independently verified effect evidence, complete only an owed causal status reply, and never repeat the effect. For historical-debt or needs-audit items, preserve quarantine with no repeated effect. Only genuinely unconsumed current items may route through the normal Handler authority and CTA-disposition flow."] | out=[ref:recovery-repaired]
@CHECK rid=check:no-duplicate-effect | assert="no external effect was repeated solely because a UUID was missing from the compact cursor" | fail=ABORT | msg="Recovery duplicated or cannot exclude duplication of an effect; remain DEGRADED and surface the item."
@STEP rid=step:recovery-prove | n:int=5 | op=std:ai.prompt@v1 | in=[ref:recovery-repaired] | args=[task="Keep unresolved debt visible in status. Use one fresh real addressed message to prove detection, validation, causal action or explicit no-reply disposition, durable disposition, cursor checkpoint, heartbeat, and end-to-end runtime wake or re-entry. If wake is unavailable, select PARKED instead of LISTENING."] | out=[ref:recovery-proof]
@STEP rid=step:recovery-restore | n:int=6 | op=std:ai.prompt@v1 | in=[ref:recovery-proof] | args=[task="Restore LISTENING only when the fresh proof passed and no readiness-blocking debt remains. Otherwise retain DEGRADED for failed correctness or PARKED for unavailable wake, while leaving the mandatory base collaboration and authorized current work explicit."] | out=[ref:recovery-terminal]
@CHECK rid=check:recovery-ready | assert="any LISTENING verdict is backed by a fresh real-message end-to-end proof and no unresolved readiness-blocking debt" | fail=WARN | msg="Do not restore LISTENING; retain DEGRADED or PARKED with the exact residual gap."

@STAMP ts:ts=2026-07-23T00:00:00Z | src="Alexandru Mares | allemaar.com" | method=merged
