@DOC ver=2.0 | id=agent-mailbox-collab-window | title="Agent Mailbox Collab Window" | kind=workflow | profile=exec | fmt=min | classification=public | guide="https://yon.younndai.com/yon-guide.txt" | parent=agent-mailbox
@INTENT goal="Add a bounded participant-local Work-or-Listen lease after the base Agent Mailbox collaboration is established, without negotiating peer cadence or claiming persistence or wake capability the runtime cannot prove"
@STAMP ts:ts=2026-07-23T00:00:00Z | src="Alexandru Mares | allemaar.com" | method=merged

@SEC name="Package contract"
@NOTE text="Package id collab-window version 2; compatible with Agent Mailbox base 1.x; participant-local directive whose activation cadence horizon rearm expiry stop and cleanup never require peer acceptance"
@MAP rid=map:collab-window-states | name=CollabWindowStates | pairs=["OFF"->"no availability lease selected","WORKING"->"authorized work is executing inside the lease","LISTENING"->"detection reconciliation heartbeat and end-to-end runtime wake or re-entry are proven","PARKED"->"base collaboration remains open but automatic wake or continuity is unavailable","DEGRADED"->"a miss cursor inconsistency heartbeat failure or capability loss revoked readiness","EXPIRED"->"the absolute lease deadline elapsed","STOPPED"->"the Handler or participant ended the lease and cleanup was verified"]
@MAP rid=map:collab-window-defaults | name=CollabWindowDefaults | pairs=["settling horizon"->"10 minutes after establishment unless the Handler selects another bounded deadline","longer operation"->"renewable bounded lease with one absolute Handler-approved deadline","unbounded or non-stop"->"unsupported; explain the finite lease requirement","fallback"->"PARKED when continuity is unavailable; DEGRADED when promised capability fails"]
@RULE rid=rule:base-first | lvl=MUST | when="activating this package" | then="establish the mandatory CORE or FULL base collaboration first and preserve it when this local package is unavailable parks expires stops or degrades"
@RULE rid=rule:requested-vs-proven | lvl=MUST | when="reporting availability" | then="record both the Handler-requested state and the operationally proven state, and never render LISTENING from intention alone"
@RULE rid=rule:listening-proof | lvl=MUST | when="entering LISTENING" | then="prove message detection, age-independent disposition reconciliation, observable heartbeat, hard deadline, cancellation, and end-to-end runtime wake or re-entry for the active adapter"
@RULE rid=rule:no-infinite-window | lvl=MUST_NOT | when="the Handler requests non-stop or unbounded Work-or-Listen" | then="start an infinite execution or listener loop; propose a renewable bounded lease with an absolute deadline instead"
@RULE rid=rule:one-primary | lvl=MUST | when="collab-window is active for a participant" | then="keep it as that participant's sole primary operating package; missed-message-recovery is the only permitted overlay in version 2"
@RULE rid=rule:toggle-preflight | lvl=MUST | when="the Handler starts stops or toggles Collab Window" | then="run the same capability and cleanup checks as an explicit transition; toggle language never bypasses preflight"
@RULE rid=rule:window-unilateral | lvl=MUST_NOT | when="selecting starting rearming renewing expiring stopping or cleaning up a Collab Window" | then="publish a mode proposal or require peer acceptance counter rejection renewal or matching cadence"
@RULE rid=rule:peer-duty-separate | lvl=MUST | when="the local participant needs a peer to deliver review check reply or remain available by a deadline" | then="send an ordinary scoped request propose or FULL claim under the base protocol instead of encoding the duty as a Collab Window"
@RULE rid=rule:rearm-after-disposition | lvl=MUST | when="a valid inbound message is handled during the lease" | then="persist its durable disposition and any required primer update before re-arming detection"
@RULE rid=rule:revoke-on-miss | lvl=MUST | when="a message miss cursor inconsistency lost heartbeat or wake failure is reported" | then="transition immediately to DEGRADED, stop and verify termination of any nonconforming listener, and load missed-message-recovery"

@SEC name="Execution"
@STEP rid=step:window-resolve | n:int=1 | op=std:ai.prompt@v1 | args=[task="Resolve this participant's Handler-selected bounded horizon or use the advisory 10-minute post-establishment or post-resume settling default. Record local requested state, absolute deadline, detection adapter, reconciliation channel, heartbeat, wake or re-entry mechanism, failure budget, cancellation, and cleanup owner. Never inspect or negotiate a peer cadence as a prerequisite."] | out=[ref:window-contract]
@CHECK rid=check:window-bounded | assert="the window has an absolute deadline, finite failure budget, observable heartbeat, cancellation path, and cleanup owner" | fail=ABORT | msg="Collab Window must remain finite and observable. Fall back to Standard Exchange or PARKED."
@STEP rid=step:window-start | n:int=2 | op=std:ai.prompt@v1 | in=[ref:window-contract] | args=[task="Activate collab-window version 2 only for this participant after base establishment. Do not write a proposal or wait for peer acceptance. Optionally publish a canonical state availability FYI only for a material coarse transition, with expects_reply false and no peer obligation."] | out=[ref:window-local-state]
@STEP rid=step:window-work | n:int=3 | op=std:ai.prompt@v1 | in=[ref:window-contract,ref:window-local-state] | args=[task="Enter WORKING only for authorized bounded work. Reconcile inbound before and after the work slice. Every valid addressed message is a call to action requiring append-only durable disposition transitions with one current effective state: acted, replied, no-reply-required, blocked by Handler-decision, rejected-scope only after refusal, deferred with an explicit owner and deadline, needs-audit, or quarantined historical-debt."] | out=[ref:window-work-state]
@STEP rid=step:window-listen | n:int=4 | op=std:cmd.run@v1 | in=[ref:window-contract,ref:window-work-state] | args=[task="Enter LISTENING only when rule:listening-proof is satisfied. Otherwise enter PARKED without blocking the base thread. Run an immediate check, then bounded event or scheduled reconciliation under the lease; wake reasoning only on a valid message, heartbeat request, watchdog alarm, cancellation, or deadline."] | out=[ref:window-listen-state]
@CHECK rid=check:window-listening | assert="LISTENING is backed by current detection, reconciliation, heartbeat, hard-deadline, cancellation, and end-to-end wake or re-entry evidence" | fail=WARN | msg="Do not claim LISTENING. Report PARKED, or DEGRADED when a previously proven capability failed."
@STEP rid=step:window-rearm | n:int=5 | op=std:ai.prompt@v1 | in=[ref:window-listen-state] | args=[task="On a valid message, return to the mandatory base exchange, act once, persist the authoritative disposition and required primer state, update the compact cursor checkpoint, then re-arm only if time and check budgets remain."] | out=[ref:window-rearmed]
@STEP rid=step:window-stop | n:int=6 | op=std:cmd.run@v1 | in=[ref:window-contract,ref:window-rearmed] | args=[task="On Handler stop, cancellation, failure, or absolute deadline, stop the owned monitor or job, verify its process or native-job identity is gone, remove owned scratch state, return scratch counts to baseline, record STOPPED EXPIRED or DEGRADED, and leave the base collaboration state explicit."] | out=[ref:window-terminal]
@CHECK rid=check:window-clean | assert="the owned monitor or job is absent, scratch returned to baseline, the terminal state is durable, and no claim of continued listening remains" | fail=ABORT | msg="Collab Window cleanup is incomplete; remain DEGRADED and surface the owned resource."

@STAMP ts:ts=2026-07-23T00:00:00Z | src="Alexandru Mares | allemaar.com" | method=merged
