@DOC ver=2.0 | id=agent-mailbox-scheduled-collab | title="Agent Mailbox Scheduled Collab" | kind=workflow | profile=exec | fmt=min | classification=public | guide="https://yon.younndai.com/yon-guide.txt" | parent=agent-mailbox
@INTENT goal="Use a host runtime's native scheduler for bounded Agent Mailbox reconciliation checks without creating a daemon, overlapping jobs, or an unbounded autonomous cycle"
@STAMP ts:ts=2026-07-23T00:00:00Z | src="Alexandru Mares | allemaar.com" | method=merged

@SEC name="Package contract"
@NOTE text="Package id scheduled-collab version 2; compatible with Agent Mailbox base 1.x; participant-local directive whose activation cadence horizon checks expiry cancellation and cleanup never require peer acceptance"
@MAP rid=map:scheduled-outcomes | name=ScheduledCollabOutcomes | pairs=["ACTIVE"->"a native job is registered inside the approved horizon","FOUND"->"a valid addressed message was reconciled and the base exchange must run","PARKED"->"scheduler or task wake is unavailable but the base thread remains usable","DEGRADED"->"a scheduled check failed its evidence or budget contract","EXPIRED"->"the absolute horizon elapsed","CANCELLED"->"the job was removed and cleanup verified"]
@RULE rid=rule:native-scheduler-only | lvl=MUST | when="activating scheduled-collab" | then="use a host-exposed native scheduler or automation capability with a bounded job identity; never invent or install a daemon service database queue or universal wake layer"
@RULE rid=rule:absolute-horizon | lvl=MUST | when="registering scheduled checks" | then="set an absolute Handler-approved deadline, finite maximum check count, finite consecutive failure budget, and cancellation path"
@RULE rid=rule:no-overlap | lvl=MUST | when="a scheduled check fires while the prior owned check is still active" | then="skip the new check, record the overlap, and never run concurrent reconciliation jobs for the same package instance"
@RULE rid=rule:bounded-check | lvl=MUST | when="a scheduled check runs" | then="perform one bounded transport sync and age-independent disposition reconciliation, persist a structured outcome and heartbeat, then exit"
@RULE rid=rule:wake-honesty | lvl=MUST | when="describing scheduled operation" | then="separate successful job scheduling, folder materialization, message detection, and agent task wake; claim only the capabilities proven end to end"
@RULE rid=rule:scheduled-fallback | lvl=MUST | when="the runtime lacks a native scheduler or cannot prove wake and cancellation" | then="leave the base collaboration active, report PARKED, and offer Handler-mediated turn-taking or a bounded Collab Window"
@RULE rid=rule:no-infinite-schedule | lvl=MUST_NOT | when="a schedule has no absolute horizon or maximum check count" | then="register or continue it"
@RULE rid=rule:no-half-active-schedule | lvl=MUST_NOT | when="the scheduler capability check fails or any load-bearing prerequisite is absent" | then="register or run a scheduled job; terminate local package activation as PARKED while leaving the base collaboration active"
@RULE rid=rule:schedule-unilateral | lvl=MUST_NOT | when="selecting registering renewing expiring cancelling or cleaning up Scheduled Collab" | then="publish a mode proposal or require peer acceptance counter rejection renewal or matching cadence"
@RULE rid=rule:scheduled-peer-duty-separate | lvl=MUST | when="the local participant needs a peer to deliver review check reply or remain available by a deadline" | then="send an ordinary scoped request propose or FULL claim under the base protocol instead of encoding the duty as Scheduled Collab"

@SEC name="Execution"
@STEP rid=step:schedule-resolve | n:int=1 | op=std:ai.prompt@v1 | args=[task="Resolve the native scheduler capability, exact mailbox and participant filters, interval, absolute deadline, maximum check count, failure budget, no-overlap key, task-wake behavior, cancellation mechanism, result location, and cleanup evidence. If any load-bearing capability is absent, select PARKED."] | out=[ref:schedule-contract]
@CHECK rid=check:schedule-capable | assert="a native bounded scheduler, stable job identity, hard deadline, maximum check count, no-overlap guard, cancellation, result surface, and end-to-end task wake or agent re-entry mechanism are available and evidenced" | fail=ABORT | msg="Terminate this local package activation as PARKED before registration. Keep the base collaboration active."
@STEP rid=step:schedule-activate | n:int=2 | op=std:ai.prompt@v1 | in=[ref:schedule-contract] | args=[task="Activate scheduled-collab version 2 only for this participant after base establishment. Do not write a proposal or wait for peer acceptance. Optionally publish a canonical state availability FYI only for a material coarse transition, with expects_reply false and no peer obligation."] | out=[ref:schedule-local-state]
@STEP rid=step:schedule-register | n:int=3 | op=std:cmd.run@v1 | in=[ref:schedule-contract,ref:schedule-local-state] | args=[task="Register one native job with the absolute deadline, maximum check count, failure budget, and no-overlap key. Record the scheduler job identity and next due time. Do not create a watcher daemon or an unbounded shell loop."] | out=[ref:schedule-job]
@STEP rid=step:schedule-check | n:int=4 | op=std:cmd.run@v1 | in=[ref:schedule-contract,ref:schedule-job] | args=[task="At each firing, refuse overlap, run one immediate bounded correctness-channel sync, reconcile the whole addressed inbox against durable dispositions and the compact cursor, emit FOUND PARKED DEGRADED or no-message heartbeat, then exit before the next interval."] | out=[ref:schedule-result]
@STEP rid=step:schedule-react | n:int=5 | op=std:ai.prompt@v1 | in=[ref:schedule-result] | args=[task="On FOUND, re-enter the mandatory base exchange and persist the message disposition before any next check. On failure-budget exhaustion, cursor inconsistency, or missed message, mark DEGRADED and load missed-message-recovery. Never infer that a job firing means the agent task was woken unless re-entry is observed."] | out=[ref:schedule-state]
@STEP rid=step:schedule-stop | n:int=6 | op=std:cmd.run@v1 | in=[ref:schedule-contract,ref:schedule-job,ref:schedule-state] | args=[task="At cancellation, absolute deadline, maximum checks, or degradation, remove the native job, verify it is absent, verify no owned check process remains, remove owned scratch, and record CANCELLED EXPIRED or DEGRADED."] | out=[ref:schedule-terminal]
@CHECK rid=check:schedule-clean | assert="the native job and owned check processes are absent, scratch returned to baseline, and the terminal result is durable" | fail=ABORT | msg="Scheduled Collab cleanup is incomplete; remain DEGRADED and surface the owned resource."

@STAMP ts:ts=2026-07-23T00:00:00Z | src="Alexandru Mares | allemaar.com" | method=merged
