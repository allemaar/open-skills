@DOC ver=2.0 | id=orient-status | title="/orient-status" | kind=skill | profile=exec | fmt=min | guide="https://yon.younndai.com/yon-guide.txt"
@INTENT goal="Compute a fresh ephemeral read of where the work stands — position, remaining, banded ETA — via a bounded read-only subagent; --resume re-frames for cold re-entry. Emit a record conformant to orient-spec/orient-record.yon." | audience=agent
@STAMP ts:ts=2026-06-22T00:00:00Z | src="agent:claude-code" | method=generated
@NOTE text="Emits a slice of the shared orientation record (orient-spec/orient-record.yon): the envelope @CFG id=orient, @CFG id=subject (carries intent_status, the gate denominator), @CFG id=snapshot, @CFG id=remaining, @CFG id=forecast, and @CFG id=resume in --resume mode; list fields as sidecar @MAP; per-field provenance as @MAP. Reserved tags only; validate --profile exec; never run yon format on an instance. Enum membership and these @RULE/@CHECK gates are emitter obligations, not parser-enforced under exec."

@SEC name="Inputs"
@INPUT rid=in:scope | name="scope" | type=artifact | required:bool=true
@INPUT rid=in:intent | name="intent" | type=artifact | required:bool=false
@INPUT rid=in:mode | name="mode" | type=artifact | required:bool=false

@SEC name="Rules"
@RULE rid=rule:intent-gates | lvl=MUST | when="intent is absent or ungrounded" | then="gate every intent-dependent field as needs-goal and cap its provenance tier to guessed, and never fabricate a goal"
@RULE rid=rule:eta-band | lvl=MUST | when="emitting the forecast" | then="express ETA as a band from eta_low to eta_high tagged estimate-not-observed, and with no plan render ETA unknown"
@RULE rid=rule:no-fabricated-pct | lvl=MUST_NOT | when="the denominator is unknown" | then="emit a fabricated percentage or a confident phase"
@RULE rid=rule:fail-closed | lvl=MUST | when="evidence is zero or barren" | then="set gate_status to degraded or indeterminate with a sentinel value and never a plausible ready or blocked"
@RULE rid=rule:trust-trailer | lvl=MUST | when="emitting the markdown read" | then="end with the trust trailer naming the single load-bearing guess on a lean-here line"
@RULE rid=rule:ephemeral | lvl=MUST | when="emitting any record" | then="set ephemeral true and a fresh computed_at, persist no derived snapshot, and rely on a caller-supplied or harness-held reference point"
@RULE rid=rule:bounded-sweep | lvl=MUST | when="gathering evidence" | then="delegate to one read-only depth-1 subagent with a budget and a hard timeout and a stop-condition, and return only the bundle with a re-runnable proof on every attested field"
@RULE rid=rule:list-encoding | lvl=MUST | when="emitting a list field" | then="emit it as a sidecar @MAP and never a bare bracket-list inside a set and never run yon format on the instance"
@RULE rid=rule:footer-installed | lvl=MUST | when="the family footer suggests a next skill" | then="suggest only an installed skill and otherwise fall back to a prose hint or plan-create"
@RULE rid=rule:resume-terminator | lvl=MUST | when="mode is resume" | then="end in exactly one next action plus its counter-case plus the single dropped alternative and never a menu"

@SEC name="Steps"
@STEP rid=step:bind-intent | n:int=1 | op=std:data.transform@v1 | args=[task="Bind the intent input and set intent_status to stated or inferred or absent. Do not prompt the caller."] | in=[rid:in:intent] | out=[ref:intent-status]
@STEP rid=step:sweep | n:int=2 | op=std:data.search@v1 | args=[task="Spawn one bounded read-only depth-1 subagent over scope using the cheap-first ladder git then plan then conversation; budget 8 to 12 calls, timeout 60 to 90 seconds, stop at the first confident tier; return only signal with proof per the SKILL.md return fields."] | in=[rid:in:scope] | out=[ref:evidence]
@STEP rid=step:compute | n:int=3 | op=std:data.transform@v1 | args=[task="Compute the subject and snapshot and remaining and forecast slices; tag every field with a provenance tier; gate intent-dependent fields when intent-status is absent; set the fail-closed gate_status on zero evidence."] | in=[ref:evidence,ref:intent-status] | out=[ref:record]
@STEP rid=step:resume | n:int=4 | op=std:data.transform@v1 | args=[task="When mode is resume re-frame to the resume-pointer (the exact stop-point plus one next action plus its counter-case plus the single dropped alternative) and suppress the full snapshot; otherwise pass the record through unchanged."] | in=[ref:record,rid:in:mode] | out=[ref:record-final]
@STEP rid=step:emit | n:int=5 | op=std:io.emit@v1 | args=[surface="caller",task="Emit the triple bundle conformant to orient-record: the @CFG id=orient envelope, @CFG id=subject identity, the snapshot and remaining and forecast slices (and resume in resume mode), list fields as sidecar @MAP, per-field provenance @MAP, the markdown read with the trust trailer, the visual plus its mandatory ASCII fallback, and the installed-only family footer."] | in=[ref:record-final] | out=[ref:bundle]

@SEC name="Gates"
@CHECK rid=chk:scope | assert="rid:in:scope != null" | fail=ABORT | msg="No scope to orient on — name the project, repo, folder, or task."
@CHECK rid=chk:eta-band | assert="the forecast eta is a band or unknown and never a point estimate" | fail=WARN | msg="ETA must be a band or unknown, not a point estimate."
@CHECK rid=chk:fail-closed | assert="evidence is not barren or gate_status is degraded or indeterminate" | fail=ABORT | msg="Barren evidence must fail closed, never a plausible ready verdict."

@SEC name="Next skills"
@STEP rid=step:nsp | n:int=99 | op=std:ai.prompt@v1 | args=[task="Run the Next Skills protocol: surface the next-skills front-matter recommendations for the caller to pick. Offer only and never auto-invoke."] | in=[] | out=[ref:nsp-offer]

@SEC name="Self-improvement"
@STEP rid=step:sip | n:int=100 | op=std:ai.prompt@v1 | args=[task="Run the Self-Improvement Protocol: if this run surfaced a concrete blocking-or-recurring weakness in this skill, propose a specific fix via ask-gate for handler approval. Conservative, silent otherwise, never auto-apply."] | in=[] | out=[ref:sip-offer]

