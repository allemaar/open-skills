@DOC ver=2.0 | id=insight-adversarial | title="Multi-Pass Adversarial Critique with Persona Selection" | kind=skill | profile=exec | fmt=min | guide="https://yon.younndai.com/yon-guide.txt"
@INTENT goal="Run structured adversarial review using a panel of distinct critic personas. 1–3 passes. First pass selects 4+ personas; subsequent passes add 2–4 new personas. Personas tailored to target type." | trigger="user says adversarial, red team this, multi-POV review, stress-test, poke holes, what am I missing, attack my plan, critique from multiple angles, is this solid, what would a skeptic say"
@STAMP ts:ts=2026-05-18T00:00:00Z | src="Alexandru Mares | allemaar.com" | method=manual

# --- Governance ---

@SEC name="Governance"
@RULE rid=rule:classify-first | lvl=MUST | when="starting a pass" | then="classify target type before selecting personas"
@RULE rid=rule:min-4 | lvl=MUST | when="selecting personas" | then="select minimum 4 personas per pass (including Claude's Own POV)"
@RULE rid=rule:claude-pov-last | lvl=MUST | when="every pass" | then="include Claude's Own POV as the final persona"
@RULE rid=rule:no-reuse | lvl=MUST_NOT | when="across passes" | then="reuse a persona — track used personas explicitly at top of each pass"
@RULE rid=rule:no-solutions-in-pass | lvl=MUST_NOT | when="inside a persona pass" | then="offer solutions — remediation belongs in synthesis (Step 4) only"
@RULE rid=rule:no-soft | lvl=MUST_NOT | when="rendering findings" | then="soften findings to be diplomatic"
@RULE rid=rule:new-personas-pass2 | lvl=SHOULD | when="running pass 2" | then="add 2–4 genuinely new personas"
@RULE rid=rule:tailor-personas | lvl=SHOULD | when="selecting personas" | then="tailor selection to target type"
@RULE rid=rule:user-suppress | lvl=MAY | when="user explicitly requests it" | then="suppress a specific persona"

# --- Caller Options ---

@SEC name="Caller Options"
@STEP rid=step:cop | n:int=0 | op=std:ai.prompt@v1 | args=[task="Run the Caller Options protocol (caller-options/protocol.yon): triage for material optionality across declared venues and modes; surface to the caller unless one path dominates; bind the chosen mode and venue. Skip if a resolved-invocation marker is present."] | out=[ref:cop-choice]
@CHECK rid=check:cop | assert="ref:cop-choice is resolved before the skill's own steps run" | fail=WARN | msg="Caller Options should resolve venue and mode before execution."

# --- Pass Mechanics ---

@SEC name="Pass Mechanics"
@MAP name=PassFlow | pairs=["Pass-1"->"Classify target → select 4–5 personas → run each → synthesize verdict","Pass-2"->"Check against Pass 1 findings → add 2–4 NEW personas not used before → re-run → delta verdict","Pass-3"->"Final wrap-up. If all critical issues resolved or within params, declare done. Otherwise escalate."]

# --- Step 1: Target Classification ---

@SEC name="Step 1 — Target Classification"
@MAP name=TargetTypes | pairs=["plan"->"Is this executable? — Scope drift, undeclared deps","design/architecture"->"Does structure match intent? — Coupling, ownership violations","yon-workflow"->"Does this execute correctly end-to-end? — Gate logic, step ordering, missing catches","document/spec"->"Is this complete and unambiguous? — Gaps, contradictions, assumed context","idea/concept"->"Is the core premise sound? — Wrong problem, premature solution","business/product"->"Is this viable and desirable? — Market assumptions, cost blindness","code/implementation"->"Is this correct and maintainable? — Edge cases, coupling, test coverage","ui/ux"->"Will real users succeed with this? — Flow breakdowns, mental model gaps"]

@STEP rid=step:classify | n:int=1 | op=std:ai.prompt@v1 | args=[task="Classify the target using TargetTypes. Identify primary risk vector."] | out=[ref:target-class] | rules=[rid:rule:classify-first]
@STEP rid=step:load-roster | n:int=2 | op=std:fs.read@v1 | args=[path="personas/roster.md"] | out=[ref:roster] | note="Load the full persona library to inform selection."

# --- Step 2: Persona Selection Logic ---

@SEC name="Step 2 — Persona Selection"
@STEP rid=step:select-personas | n:int=3 | op=std:ai.prompt@v1 | args=[task="Pick primary persona (whose domain most directly overlaps target's failure mode), 2–3 supporting personas (different angles, complement primary, no duplicates), and Claude's Own POV last. Track used personas explicitly."] | in=[ref:target-class,ref:roster,ref:used-personas] | out=[ref:selected-personas] | rules=[rid:rule:min-4,rid:rule:claude-pov-last,rid:rule:no-reuse,rid:rule:tailor-personas,rid:rule:user-suppress]
@CHECK rid=check:persona-count | assert="ref:selected-personas count >= 4 AND includes Claude's Own POV last" | fail=ABORT | msg="Persona selection violates minimums."
@CHECK rid=check:no-reuse | assert="ref:selected-personas has zero overlap with ref:used-personas" | fail=ABORT | msg="Persona reuse detected. Pick different personas."

# --- Step 3: Run Each Persona Pass ---

@SEC name="Step 3 — Run Each Persona Pass"
@MAP name=PersonaFormat | pairs=["header"->"## 🔴 [PERSONA NAME]","lens-line"->"*Lens: [one-sentence description]*","critique"->"specific finding(s), no softening, no generalities","constraint"->"findings must be distinct across personas in this pass"]

@STEP rid=step:run-passes | n:int=4 | op=std:ai.prompt@v1 | args=[task="For each selected persona: state name and lens (one sentence), run critique with at least one specific named finding. Format per PersonaFormat. Claude's Own POV last — first person, clear position, no hedging."] | in=[ref:selected-personas,ref:target-class] | use=[cfg:PersonaFormat] | out=[ref:persona-findings] | rules=[rid:rule:no-soft,rid:rule:no-solutions-in-pass]

# --- Step 4: Synthesis ---

@SEC name="Step 4 — Synthesis"
@MAP name=SynthesisSections | pairs=["critical-issues"->"top 3, ranked by severity","blind-spots"->"what aggregate reveals that no single persona fully caught","remediation"->"minimum surgical fix per Critical Issue. If unfixable, say so.","one-line-verdict"->"honest, specific, no hedging"]

@STEP rid=step:synthesize | n:int=5 | op=std:ai.prompt@v1 | args=[task="Synthesize per SynthesisSections."] | in=[ref:persona-findings] | use=[cfg:SynthesisSections] | out=[ref:pass-verdict]

# --- Step 5: Pass Wrap Logic ---

@SEC name="Step 5 — Pass Wrap"
@MAP name=PassWrap | pairs=["pass-1-or-2"->"Ask user if they want another pass. If yes → load new personas, run delta critique focused on unresolved issues.","pass-3"->"Check if all Critical Issues resolved or explicitly accepted. If yes → final consolidated verdict + declare wrap. If no → flag remaining open issues, recommend escalation (e.g. /plan-create)."]

@STEP rid=step:wrap | n:int=6 | op=std:ai.prompt@v1 | args=[task="Apply pass-wrap logic per PassWrap based on current pass number and verdict."] | in=[ref:pass-verdict] | use=[cfg:PassWrap] | out=[ref:wrap-decision]
@CATCH target=rid:step:select-personas | on="user-requests-additional-pass" | do=rid:step:select-personas | note="Loop back; ref:used-personas now includes prior-pass personas."

# --- Files ---

@SEC name="Files"
@NOTE text="personas/roster.md — Full persona library. Load during Step 1 to inform selection."


# --- Next Skills ---

@SEC name="Next Skills"
@STEP rid=step:nsp | n:int=99 | op=std:ai.prompt@v1 | args=[task="Run the Next Skills protocol: surface the next-skills front-matter recommendations for the caller to pick. Offer only; never auto-invoke. Skip silently if the next-skills list is empty."] | in=[] | out=[ref:nsp-offer]


# --- Self-improvement ---

@SEC name="Self-improvement"
@STEP rid=step:sip | n:int=100 | op=std:ai.prompt@v1 | args=[task="Run the Self-Improvement Protocol (self-improve/protocol.yon): if this run surfaced a concrete, blocking-or-recurring weakness in THIS skill (ambiguity, uncovered edge case, forced deviation, misfired gate, stale cross-reference, user correction), draft a specific diff and surface it via /ask-gate for handler approval. Conservative — silent otherwise; dedup against already-proposed; never auto-apply."] | in=[] | out=[ref:sip-offer]

@STAMP ts:ts=2026-07-21T00:00:00Z | src="Alexandru Mares | allemaar.com" | method=generated
