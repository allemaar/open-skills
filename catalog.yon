@DOC ver=2.0 | id=open-skills-catalog | title="open-skills — machine catalog" | kind=catalog | profile=full | fmt=min | license="Apache-2.0" | guide="https://yon.younndai.com/yon-guide.txt"
@INTENT goal="Machine-readable catalog of the open-skills pack — one record per skill — for agent and registry discovery and install. Generated by tools/spine.mjs from each skill's SKILL.md front-matter contract plus live protocol.yon facts."
@STAMP ts:ts=2026-06-15 | src=tool | method=generated | scope="tools/spine.mjs"
@NOTE text="open-skills by Alexandru Mares (allemaar.com). Apache-2.0. Not a YounndAI product; YON and YounndAI are trademarks of MARLINK TRADING SRL. Generated — do not edit by hand; run tools/spine.mjs."
@SEC name="skills"
@META id=ask-gate | visibility=public | protocol=yes | profile=exec | description="The Ask-Gate Protocol (AGP). Before surfacing an AskUserQuestion, triage whether the question is genuinely the handler's call (anti-nag); ask routine questions directly after a quality checklist, but escalate high-stakes / branching / irreversible ones through /insight-critique then /insight-assess first. Trigger via /ask-gate, or automatically before any handler-facing question. Not /caller-options (routes a skill's venue/mode) or /next-skills (recommends successors) — AGP governs the question itself." | triggers="/ask-gate" | gates="genuinely-handler-call=SKIP" | rules="question-moment-only=MUST; depth-guard=MUST; no-recurse=MUST_NOT; triage-first=MUST; escalate-high-stakes=SHOULD; escalate-once=MUST_NOT" | next="insight-cross-examine; insight-assess; reflect" | install="cp -r skills/ask-gate <runtime>/skills/ask-gate" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=audit-coupled-constant | visibility=public | protocol=no | profile=none | description="Audit every site of a constant whose value is duplicated across multiple call sites (retry budgets, timeouts, page sizes, magic numbers, feature flags). The author-maintained `SEE ALSO` trail is documentation, not enforcement — one missed site means the trail lies. Trigger on /audit-coupled-constant, 'audit budget consistency', 'find all sites of this value', 'check coupled invariant', 'before raising this constant', or after any edit to a constant that has SEE ALSO cross-references in its comments. Pairs naturally before /cold-review on a 'raise the budget' PR. Not for extract-constant refactors that consolidate scattered values into a single named import — use /improve-codebase-architecture. Not for constants enforced by the type system (TypeScript `as const` literal imported everywhere) where the compiler is the audit — skip." | triggers="/audit-coupled-constant; audit budget consistency; find all sites of this value; check coupled invariant; before raising this constant" | gates="" | rules="" | next="cold-review; insight-critique" | install="cp -r skills/audit-coupled-constant <runtime>/skills/audit-coupled-constant" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=caller-options | visibility=public | protocol=yes | profile=exec | description="The Caller Options protocol (COP). When a participating skill runs, detect optionality in Venue (inline / delegated sub-agent / fan-out) and Mode, evaluate it, and surface the choice to the caller instead of picking silently. Trigger via /caller-options, or automatically when a skill carrying the COP opt-in block runs. Not a session mode — use orchestrate-mode or multi-agent-mode for that; COP routes one skill invocation." | triggers="/caller-options" | gates="optionality=SKIP; depth=ABORT; choice=ABORT; delegated-gate=ABORT" | rules="triage-skip=MUST; never-delegate=MUST_NOT; self-orch=MUST_NOT; conservative-venue=MUST; tiered-assess=MUST; depth-1-brief=MUST; no-reentry=MUST_NOT; caller-kind=MUST; inspect=MUST" | next="multi-agent-mode; orchestrate-mode; ask-gate" | install="cp -r skills/caller-options <runtime>/skills/caller-options" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=cold-review | visibility=public | protocol=yes | profile=exec | description="Run outside-agent review of actual work artifacts against objectives, with classification, fresh reviewer lenses, evidence-based findings, scoring, and thresholds. Trigger on /cold-review, 'cold review this', 'get outside review', 'have fresh agents inspect this work', or 'review this with fresh context'. Use verify for self-gating intent/plan/execution; use insight-adversarial for persona critique of ideas or plans." | triggers="/cold-review; cold review this; get outside review; have fresh agents inspect this work; review this with fresh context" | gates="cop=WARN; target-exists=ABORT; critical-caps-verdict=WARN" | rules="artifacts-only=MUST; not-idea-tool=MUST_NOT; max-three=MUST_NOT; degraded-labeled=MUST; narrow-evidence-brief=MUST; reviewers-read-only=MUST_NOT; concrete-not-memory=MUST; classify-first=MUST; fresh-agents=MUST; evidence-required=MUST; severity-tiers=MUST; score-and-verdict=MUST; not-verification=MUST_NOT" | next="plan-create; insight-cross-examine; github-sync; double-check" | install="cp -r skills/cold-review <runtime>/skills/cold-review" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=defuddle | visibility=public | protocol=no | profile=none | description="Extract clean markdown from web pages via Defuddle CLI (strips nav/ads/clutter, saves tokens). Trigger whenever the user pastes a URL or says 'read this article', 'fetch this page', 'summarize this blog post', 'pull this doc'; use this instead of WebFetch for any standard article, doc, or blog. Skip for APIs/JSON/raw downloads." | triggers="read this article; fetch this page; summarize this blog post; pull this doc" | gates="" | rules="" | next="insight-cross-examine; prime-sweep; obsidian-markdown" | install="cp -r skills/defuddle <runtime>/skills/defuddle" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=design-an-interface | visibility=public | protocol=no | profile=none | description="Generate multiple radically different interface designs for a module, then compare and synthesize. Use when the user wants to design an API, explore interface options, compare module shapes, or says 'design it twice' / 'give me options' / 'what should this interface look like'. Also trigger proactively when a user is about to implement something non-trivial and hasn't locked in an interface yet. Not /insight-explore (brainstorms approaches as prose) or /plan-create (turns a chosen design into a phased plan) — this produces concrete, comparable interface designs." | triggers="/design-an-interface; design an API; explore interface options; compare module shapes; design it twice; give me options; what should this interface look like" | gates="" | rules="" | next="plan-create; improve-codebase-architecture" | install="cp -r skills/design-an-interface <runtime>/skills/design-an-interface" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=double-check | visibility=public | protocol=yes | profile=exec | description="Targeted re-verification of a specific claim, output, or decision. Re-read sources, challenge, cross-reference, and deliver a verdict. Trigger when the user runs /double-check or asks to 'verify this', 're-check this', 'are you sure about this', 'go over this again', or 'make sure this is right'. Not /verify (formal phase gate needing intent+plan+execution artifacts) or /insight-critique (advisory review of an output) — double-check is a quick targeted re-read of one claim." | triggers="/double-check; verify this; re-check this; are you sure about this; go over this again; make sure this is right" | gates="cop=WARN; target=ABORT; verdict=ABORT" | rules="sources=MUST; adversarial=MUST; evidence=MUST; no-rubber-stamp=MUST_NOT; offer-rerun=SHOULD" | next="verify; github-sync; insight-adversarial" | install="cp -r skills/double-check <runtime>/skills/double-check" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=extract-signal | visibility=public | protocol=yes | profile=exec | description="An elastic signal-extraction methodology run under /multi-agent-mode. INFERS from the call what signal, what form, what stakes, and where output goes. Default is agentic — a normal call spawns a freshly-primed sub-agent that gathers, vets, and returns the signal; when extract-signal IS the agent (in-session / new-session) it works inline with output inline by default (or to a file if specified). Composes techniques per task: gather (/prime-sweep, /prime-fetch, /prime-expand), diverge (/insight-explore), vet (/insight-critique → /insight-assess), cold second opinion (/cold-review-style). Vetting scales with stakes; the presented signal carries provenance and is sensitivity-matched to its destination. Trigger on /extract-signal, 'extract the signal on X and present it as Y', 'gather + vet + report the signal about X'. Not the prime-* / insight-* / cold-review skills it composes; not /multi-agent-mode (the mode it runs under)." | triggers="/extract-signal; extract the signal on X and present it as Y; gather + vet + report the signal about X" | gates="empty=WARN" | rules="relocation=MUST; agentic-default=MUST; in-session=MUST; depth=MUST_NOT; no-fixed-seq=MUST_NOT; vet-to-stakes=MUST; contradiction=MUST; blocker=MUST; provenance=MUST; sensitivity=MUST; concurrency=MUST; terminate=SHOULD" | next="insight-assess; plan-create; handoff" | install="cp -r skills/extract-signal <runtime>/skills/extract-signal" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=github-sync | visibility=public | protocol=yes | profile=exec | description="Review the session's git changes, summarize them for approval, then commit and push to GitHub. Trigger when the user runs /github-sync or says 'sync to github', 'commit and push', 'push this session', 'wrap up and push', 'save this session to git'. For commit-only (no push) or partial staging, do not use this skill." | triggers="/github-sync; sync to github; commit and push; push this session; wrap up and push; save this session to git" | gates="proposed-messages-clean=ABORT; approved=ABORT; no-drift=ABORT; staged-match=ABORT; message-exact=ABORT; attribution-clean=ABORT" | rules="no-commit-without-approval=MUST_NOT; no-blind-add=MUST_NOT; no-vague-groups=MUST_NOT; no-unlisted-files=MUST_NOT; path-output-literal=SHOULD; no-hidden-message-lines=MUST_NOT; no-force-push=MUST_NOT; no-attribution=MUST_NOT; verify-clean-before-push=MUST; message-only-default=MAY; nothing-to-commit=MUST" | next="insight-retro; handoff" | install="cp -r skills/github-sync <runtime>/skills/github-sync" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=handoff | visibility=public | protocol=yes | profile=exec | description="Generate a structured cold-agent handoff brief (YAML frontmatter + Obsidian markdown + YON blocks) that any fresh LLM session can pick up and execute. Trigger when the user runs /handoff or says 'create a handoff', 'dispatch to a fresh agent', 'hand this to a cold session', 'switch to a new session', 'I have N tasks for cold agents', 'package this for another agent'. Use /orchestrate-mode instead when you want to keep the *current* session as coordinator (no artifact produced)." | triggers="/handoff; create a handoff; dispatch to a fresh agent; hand this to a cold session; switch to a new session; I have N tasks for cold agents; package this for another agent" | gates="verify=ABORT; sources=WARN" | rules="verifiable=MUST; sources-gate=MUST; no-undersized=MUST_NOT; abs-paths=MUST; wikilinks=MUST; mkdir=MUST; no-runtime-names=MUST_NOT; file-canonical=MUST_NOT" | next="handoff-execute; github-sync; orchestrate-mode" | install="cp -r skills/handoff <runtime>/skills/handoff" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=handoff-execute | visibility=public | protocol=yes | profile=exec | description="Execute a handoff brief with enforced source-read discipline — load the brief's @SOURCES.required tier fully before planning, cite sources per plan step, run @OUTCOME.verify after, emit the retro per @GROUND_TRUTH_REQUIRED. Trigger when the user runs /handoff-execute <brief-path>, or pastes the activation phrase emitted by /handoff. Not auto-triggered — the receiving session invokes explicitly. Use /plan-execute for PLAN.md files (different schema); use /handoff to *create* a brief; use /cold-review for outside-agent review, not for executing the work itself." | triggers="/handoff-execute; /handoff-execute <brief-path>" | gates="brief-valid=ABORT; sources-loaded=ABORT; advisory-warning=WARN; premise-intact=ABORT; verify-cmd-resolvable=WARN; plan-cites-sources=WARN; plan-covers-acceptance=WARN; retro-has-ground-truth=ABORT; retro-write-fallback=WARN" | rules="handoff-briefs-only=MUST; not-self-gate=MUST_NOT; no-silent-retry=MUST_NOT; on-demand-optional=SHOULD; no-scope-expansion=MUST_NOT; retro-canonical=MUST; retro-write-failure=MUST; read-required-before-plan=MUST; premise-preflight=MUST; verify-cmd-preflight=SHOULD; cover-acceptance=MUST; gate-status=SHOULD; retro-ground-truth=MUST; cite-sources=SHOULD; no-invented-sources=MUST_NOT; no-auto-resolve=MUST_NOT" | next="cold-review; insight-critique; github-sync" | install="cp -r skills/handoff-execute <runtime>/skills/handoff-execute" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=improve-codebase-architecture | visibility=public | protocol=yes | profile=exec | description="Explore a codebase to find opportunities for architectural improvement by deepening shallow modules (John Ousterhout, 'A Philosophy of Software Design'). Use when the user says 'improve architecture', 'find refactoring opportunities', 'make this more testable', 'this codebase is hard to navigate', 'consolidate these modules', 'find coupling problems', 'write an RFC for this refactor', or 'help me think about module design'. Also trigger when the user asks why tests are brittle, why a module is hard to mock, or why changing one thing always breaks another." | triggers="/improve-codebase-architecture; improve architecture; find refactoring opportunities; make this more testable; this codebase is hard to navigate; consolidate these modules; find coupling problems; write an RFC for this refactor; help me think about module design" | gates="deepening-test=ABORT; not-extraction=WARN; confirmed=ABORT" | rules="deepening-test=MUST; replace-dont-layer=MUST; no-manufactured-candidates=MUST_NOT; name-old-tests=MUST; file-agnostic-recommendations=MUST; wait-for-confirm=MUST" | next="prime-sweep" | install="cp -r skills/improve-codebase-architecture <runtime>/skills/improve-codebase-architecture" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=insight-adversarial | visibility=public | protocol=yes | profile=exec | description="Multi-pass adversarial critique from dynamically selected personas — including Claude's own POV. Trigger on: 'adversarial', 'red team this', 'multi-POV review', 'stress-test', 'poke holes', 'what am I missing', 'attack my plan', 'critique from multiple angles', 'is this solid', 'what would a skeptic say', or any request for rigorous structured criticism of a plan, design, doc, workflow, YON, idea, or system. Runs 1–3 passes. First pass selects 4+ personas from the roster. Each subsequent pass adds 2–4 new personas to the mix. Third pass wraps with a final verdict if all issues are within acceptable params. Do not skip this skill when the user wants real scrutiny — 'just give me feedback' often means they need this." | triggers="/insight-adversarial; adversarial; red team this; multi-POV review; stress-test; poke holes; what am I missing; attack my plan; critique from multiple angles; is this solid; what would a skeptic say" | gates="cop=WARN; persona-count=ABORT; no-reuse=ABORT" | rules="classify-first=MUST; min-4=MUST; claude-pov-last=MUST; no-reuse=MUST_NOT; no-solutions-in-pass=MUST_NOT; no-soft=MUST_NOT; new-personas-pass2=SHOULD; tailor-personas=SHOULD; user-suppress=MAY" | next="plan-create; plan-execute" | install="cp -r skills/insight-adversarial <runtime>/skills/insight-adversarial" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=insight-angles | visibility=public | protocol=yes | profile=exec | description="Angle & connection discovery engine. Classifies a subject (domain, type, current trends), picks lenses from a 15-family roster AND derives dynamic subject-specific ones, then runs layered passes via a context-adaptive venue (cold fan-out for independence — the cold-review effect — or inline) to surface frames, typed connections, hidden assumptions, candidate-expansions, and second-order effects, scored by novelty × relevance. Trigger on /insight-angles, 'find unseen angles', 'what connections am I missing', 'what are we not seeing', 'surface hidden assumptions', 'reframe this'. Not insight-explore (generates solution options — angles surfaces frames & connections) or insight-adversarial (attacks for flaws via personas — angles widens via lenses). Not insight-critique (reviews an output) or insight-cross-examine (the deliberation engine that orchestrates this one)." | triggers="/insight-angles; find unseen angles; what connections am I missing; what are we not seeing; surface hidden assumptions; reframe this" | gates="framed=ABORT; map=ABORT" | rules="surface-or-none=MUST; dynamic-lenses=MUST; adaptive-venue=MUST; leaf-agents=MUST; layers-compound=MUST; stay-in-lane=MUST; assessable-links=MUST; novelty-vs-trends=MUST; log-selection=MUST; no-auto-dive=MUST_NOT; no-execution=MUST_NOT; marker-quick=MUST; prefer-nonobvious=SHOULD" | next="insight-cross-examine; insight-assess; insight-explore" | install="cp -r skills/insight-angles <runtime>/skills/insight-angles" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=insight-assess | visibility=public | protocol=yes | profile=exec | description="Structured decision evaluation — pros/cons, impact assessment, quality analysis, recommendation. Trigger when the user runs /assess or asks for evaluation, comparison, or impact analysis of an approach, decision, option, or implementation. Use insight-explore for divergent option generation, insight-critique for focused output review, and insight-adversarial for multi-POV stress testing." | triggers="/assess; /insight-assess" | gates="framed=ABORT; recommendation=ABORT" | rules="concrete=MUST; full-quality=MUST; consistent-dims=MUST; no-execution=MUST_NOT; no-hedge=MUST_NOT; caveats=SHOULD; alternatives=SHOULD" | next="plan-create; insight-explore; insight-critique; prime-expand" | install="cp -r skills/insight-assess <runtime>/skills/insight-assess" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=insight-critique | visibility=public | protocol=yes | profile=exec | description="Advisory review workflow. Reviews the last plan, code, architecture, or UI output and returns a structured report: Summary, Strengths, Risks, Fixes. Use when the user runs /critique, asks to 'review this', 'critique this', or 'what's wrong with this', or wants focused feedback on a specific output. Also trigger as a quality gate before /execute. Advisory only — never blocks unless a kernel-prime violation is present. For multi-POV adversarial stress-testing with personas, use /insight-adversarial instead." | triggers="/critique; review this; critique this; what's wrong with this" | gates="cop=WARN; classify=ABORT" | rules="advisory-only=MUST; no-pad-strengths=MUST_NOT; approved-clean-only=MUST_NOT; single-classification=MUST" | next="insight-adversarial; plan-create; plan-execute" | install="cp -r skills/insight-critique <runtime>/skills/insight-critique" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=insight-cross-examine | visibility=public | protocol=yes | profile=exec | description="Context-routed deliberation engine. Takes a subject OR a set, routes by Form × Corpus to a graduated depth, discovers unseen angles & connections (via insight-angles), then runs critique → assess (+ explore, + typed hybrids for sets) and presents a decision surface — as an ask-gate or inline. Trigger on /insight-cross-examine, 'cross-examine this', 'weigh these options', 'pick between these and recommend', 'evaluate these candidates'. Not insight-critique (single-output review) or insight-assess (single-decision eval) — cross-examine orchestrates both across one-or-many with hybrids and contextual routing. Not insight-explore (pure divergence), insight-angles (the angle/connection engine it orchestrates), ask-gate (governs the question, not the subject), or plan-deep-dive (phase-by-phase plan inspection)." | triggers="/insight-cross-examine; cross-examine this; weigh these options; pick between these and recommend; evaluate these candidates" | gates="preflight=WARN; hybrids=WARN; present=ABORT" | rules="depth-guard=MUST; orchestrate-angles=MUST; depth-scale=MUST; advisory-only=MUST_NOT; no-auto-dive=MUST_NOT; hybrid-cap=MUST; surface-connection=MUST; avoid-premature-closure=SHOULD; escalate-not-grind=MUST; fit-redirect=SHOULD; ground-whole-artifact=MUST; consistent-dims=MUST; present-orthogonal=MUST; commit-verdict=MUST_NOT" | next="plan-create; insight-angles; insight-explore; insight-adversarial" | install="cp -r skills/insight-cross-examine <runtime>/skills/insight-cross-examine" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=insight-explore | visibility=public | protocol=yes | profile=exec | description="Brainstorm 3+ possible implementations before committing. Trigger when the user runs /explore or asks to 'brainstorm options', 'what are the ways to do this', 'explore approaches', 'give me alternatives', or wants divergent thinking before planning or assessment. Use insight-assess to evaluate known options, insight-critique to review an existing output, and plan-create to turn a chosen direction into an implementation plan." | triggers="/explore; brainstorm options; what are the ways to do this; explore approaches; give me alternatives" | gates="option-count=ABORT" | rules="min-options=MUST; no-code=MUST_NOT; distinct-options=MUST" | next="insight-assess; plan-create" | install="cp -r skills/insight-explore <runtime>/skills/insight-explore" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=insight-retro | visibility=public | protocol=yes | profile=exec | description="Post-implementation retrospective — map blast radius, audit documentation, extract skills, update KIs, document lessons learned. Trigger when the user runs /retro or asks for a 'retrospective', 'post-mortem', 'lessons learned', or 'what changed' after completing significant implementation work. Use insight-skill-gap when the goal is specifically to identify new or updated skills." | triggers="/retro; retrospective; post-mortem; lessons learned; what changed" | gates="radius-known=ABORT; report-complete=ABORT" | rules="check-skill-index=MUST; propose-format=MUST; concrete-followup=MUST; significance-criteria=MUST; cite-misleading=MUST; no-fix-inline=MUST_NOT; propose-high-reuse-now=SHOULD; streamline-small-blast=SHOULD" | next="insight-skill-gap" | install="cp -r skills/insight-retro <runtime>/skills/insight-retro" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=insight-skill-gap | visibility=public | protocol=yes | profile=exec | description="Scan recent work and identify if new skills should be created or existing ones updated. Trigger when the user runs /skill-gap, asks to 'check for skill gaps', 'what skills should we add', 'did we miss anything worth capturing', or after /retro flags patterns worth codifying. Use insight-retro for a broader post-implementation retrospective." | triggers="/skill-gap; check for skill gaps; what skills should we add; did we miss anything worth capturing" | gates="documented=ABORT" | rules="no-dup=MUST; naming=MUST; specific-update=MUST; check-template=MUST; no-oneoff=MUST_NOT; high-reuse-now=SHOULD" | next="new-skill-creator" | install="cp -r skills/insight-skill-gap <runtime>/skills/insight-skill-gap" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=investigate | visibility=public | protocol=yes | profile=exec | description="Gather facts (files, deps, patterns) without making changes. Trigger when the user runs /investigate or asks to 'look into this', 'explore the codebase', 'understand how this works', 'what files are involved', 'map the dependencies', or wants read-only fact-gathering before deciding what to do." | triggers="/investigate; look into this; explore the codebase; understand how this works; what files are involved; map the dependencies" | gates="cop=WARN" | rules="read-only=MUST_NOT; include-paths=MUST" | next="insight-assess; plan-create; prime-sweep" | install="cp -r skills/investigate <runtime>/skills/investigate" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=json-canvas | visibility=public | protocol=no | profile=none | description="Create and edit JSON Canvas files (.canvas) with nodes, edges, groups, and connections. Trigger when the user opens, edits, or asks to create a .canvas file, or says 'make a canvas', 'build a mind map', 'draw a flowchart in Obsidian', 'add nodes to this canvas'. Not for .md notes (use obsidian-markdown) or .base files (use obsidian-bases)." | triggers="make a canvas; build a mind map; draw a flowchart in Obsidian; add nodes to this canvas" | gates="" | rules="" | next="obsidian-markdown; obsidian-cli; obsidian-bases" | install="cp -r skills/json-canvas <runtime>/skills/json-canvas" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=monorepo-deps | visibility=public | protocol=yes | profile=exec | description="End-to-end syncpack + manypkg flow for an npm monorepo: check, fix, update, and maintain `.syncpackrc.json`. Trigger on /monorepo-deps, 'update deps', 'sync deps', 'check deps', 'fix syncpackrc', 'create syncpackrc', or 'my lock file is out of sync'. Use syncpack-usage / syncpack-cli / syncpack-config for syncpack API and config details, manypkg-usage for manypkg specifics — this skill orchestrates them." | triggers="/monorepo-deps; update deps; sync deps; check deps; fix syncpackrc; create syncpackrc; my lock file is out of sync" | gates="both-installed=ABORT; consent=ABORT; install-succeeded=ABORT; no-existing=ABORT; lint-clean=ABORT; manypkg-clean=ABORT; lock-sync=ABORT" | rules="npm-only=MUST; end-to-end=MUST; fix-before-update=MUST; cap-before-update=MUST; no-clobber=MUST_NOT; no-commit=MUST_NOT; status-summary=MUST; detect-first=MUST; verify-before-done=MUST; resync-after-fix=MUST; no-force-flags=MUST_NOT; no-auto-fire=MUST_NOT; no-ci-changes=MUST_NOT; no-pnpm-yarn=MUST_NOT" | next="verify; github-sync" | install="cp -r skills/monorepo-deps <runtime>/skills/monorepo-deps" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=multi-agent-mode | visibility=public | protocol=no | profile=none | description="Activate multi-agent mode: the lead agent still works directly but delegates independent helper slices when useful. Trigger on /multi-agent-mode, 'multi-agent mode', 'use helper agents', 'work with subagents', or 'parallelize if useful'. Use orchestrate-mode instead when the lead agent must dispatch only and not execute." | triggers="/multi-agent-mode; multi-agent mode; use helper agents; work with subagents; parallelize if useful" | gates="" | rules="" | next="extract-signal; orchestrate-mode; caller-options" | install="cp -r skills/multi-agent-mode <runtime>/skills/multi-agent-mode" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=new-skill-creator | visibility=public | protocol=yes | profile=exec | description="Scaffold a new Agent Skill end-to-end (folder, SKILL.md, optional protocol.yon for dual-doc skills, tri-runtime links for Claude Code + Codex + generic .agents/, commit and push). Trigger when the user runs /new-skill-creator or says 'create a skill', 'make a new skill for X', 'add a slash command', 'turn this workflow into a skill', 'codify this as a skill'. Not for editing existing skills — edit the SKILL.md directly. For migrating an existing single-doc skill to the dual-doc YON pattern, see section 6 below." | triggers="/new-skill-creator; create a skill; make a new skill for X; add a slash command; turn this workflow into a skill; codify this as a skill" | gates="no-overwrite=ABORT; dual-validate=ABORT" | rules="no-overwrite=MUST_NOT; confirm=MUST; kebab=MUST; boundary=MUST; under-500=MUST; three-links=MUST; self-sufficient=MUST; no-elevate=MUST" | next="cold-review" | install="cp -r skills/new-skill-creator <runtime>/skills/new-skill-creator" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=next-skills | visibility=public | protocol=yes | profile=exec | description="The Next Skills protocol (NSP). When a participating skill finishes, surface its declared follow-on skills — each with an activation phrase and a one-line why — for the caller to pick, onboarding-style. Trigger via /next-skills, or automatically when a skill carrying the NSP opt-in block completes. Not /caller-options (routes one invocation's venue/mode) or /skills-help (the static library menu) — NSP recommends successor skills after one runs." | triggers="/next-skills" | gates="" | rules="offer-only=MUST_NOT; empty-silent=MUST; loop-safe=MUST; degrade=MUST" | next="skills-help; caller-options; ask-gate" | install="cp -r skills/next-skills <runtime>/skills/next-skills" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=obsidian-bases | visibility=public | protocol=no | profile=none | description="Create and edit Obsidian Bases (.base YAML files) with views, filters, formulas, and summaries. Trigger when the user opens or edits a .base file, or says 'make a base', 'build a database view of my notes', 'add a filter/formula to this base', 'create a table/card view', 'query my vault'. Not for .md notes (obsidian-markdown) or .canvas files (json-canvas)." | triggers="make a base; build a database view of my notes; add a filter/formula to this base; create a table/card view; query my vault" | gates="" | rules="" | next="obsidian-markdown; obsidian-cli; json-canvas" | install="cp -r skills/obsidian-bases <runtime>/skills/obsidian-bases" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=obsidian-cli | visibility=public | protocol=no | profile=none | description="Drive a running Obsidian instance via the `obsidian` CLI — search vault, open/create/move notes, toggle tasks, edit properties, reload plugins, run JS, capture errors/screenshots. Trigger when the user says 'search my vault', 'open this note in Obsidian', 'list notes tagged X', 'reload my plugin', 'run this in Obsidian', 'screenshot the active note', or any command-line vault operation. Use this (not obsidian-markdown) whenever the action requires a live Obsidian session; use obsidian-markdown for raw .md file edits on disk." | triggers="search my vault; open this note in Obsidian; list notes tagged X; reload my plugin; run this in Obsidian; screenshot the active note" | gates="" | rules="" | next="obsidian-markdown; obsidian-bases; json-canvas" | install="cp -r skills/obsidian-cli <runtime>/skills/obsidian-cli" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=obsidian-markdown | visibility=public | protocol=no | profile=none | description="Write valid Obsidian-Flavored Markdown — wikilinks, embeds, callouts, frontmatter properties, tags, comments. Trigger when the user creates or edits a .md file inside an Obsidian vault, or says 'write this as an Obsidian note', 'add a callout', 'use wikilinks', 'set frontmatter properties', 'embed this image/note'. Use obsidian-cli instead when the action needs a running Obsidian (search, open, plugin reload)." | triggers="write this as an Obsidian note; add a callout; use wikilinks; set frontmatter properties; embed this image/note" | gates="" | rules="" | next="obsidian-cli; obsidian-bases; json-canvas" | install="cp -r skills/obsidian-markdown <runtime>/skills/obsidian-markdown" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=orchestrate-mode | visibility=public | protocol=no | profile=none | description="Activate orchestrator mode in the current session: the lead agent dispatches isolated worker subagents and does not execute concrete work directly. Trigger on /orchestrate-mode, 'become an orchestrator', 'orchestrator mode', 'delegate everything', or 'do not execute'. Use multi-agent-mode instead when the lead agent should still work directly while delegating helper slices." | triggers="/orchestrate-mode; become an orchestrator; orchestrator mode; delegate everything; do not execute" | gates="" | rules="" | next="handoff; cold-review; verify" | install="cp -r skills/orchestrate-mode <runtime>/skills/orchestrate-mode" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=plan-cleanup | visibility=public | protocol=yes | profile=exec | description="Post-execution cleanup — remove planning artifacts and tech debt left behind after a plan runs. Trigger when the user runs /plan-cleanup, says 'clean up artifacts', 'remove the plan file', or 'no tech debt'. Not /plan-evolve (plans the next version) — plan-cleanup only removes leftovers and adds no new work." | triggers="/plan-cleanup; clean up artifacts; remove the plan file; no tech debt" | gates="any-found=SKIP" | rules="list-first=MUST; verify-artifact=MUST; scope-bound=MUST_NOT; respect-skip=MUST_NOT; terminal-decl=MUST" | next="github-sync; insight-retro; plan-evolve" | install="cp -r skills/plan-cleanup <runtime>/skills/plan-cleanup" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=plan-create | visibility=public | protocol=yes | profile=exec | description="Propose a phased, gated implementation plan before any work begins. Trigger when the user runs /plan-create, says 'make a plan', 'plan this out', 'design before coding', 'let's plan first', 'architect this', or asks for a phased approach before implementation. Also trigger proactively when a task is complex enough that jumping straight to execution would be risky — multi-file changes, new features, architectural shifts, refactors spanning multiple components, or any task where misalignment early would be expensive to fix later. Output: a structured PLAN.md with phases, changes, risks, and verification criteria. Design only — no implementation code is written during /plan-create. Use plan-phases to restructure an existing plan, plan-execute to run an approved plan, plan-deep-dive to inspect a plan, plan-evolve to evolve shipped work, and plan-cleanup after execution." | triggers="/plan-create; make a plan; plan this out; design before coding; let's plan first; architect this" | gates="gate1=ABORT; gate2=ABORT; gate3=WARN; gate4=ABORT; final-gate=ABORT" | rules="design-only=MUST_NOT; gates-mandatory=MUST; abort-stop=MUST; warnings-proceed=MAY; sidecar-validation=MUST; global-scope=MAY; announce-progress=MUST; executable-output=MUST; cleanup-step=MUST" | next="plan-phases; plan-deep-dive; plan-execute; prime-expand" | install="cp -r skills/plan-create <runtime>/skills/plan-create" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=plan-deep-dive | visibility=public | protocol=yes | profile=exec | description="Phase-by-phase deep inspection of any multi-phase plan — stop at each phase and assess completeness, quality, and future-readiness before advancing. Trigger when the user runs /deep-dive or asks to 'do a deep dive', 'inspect each phase', 'look at this more carefully', or 'check if we're missing anything' on an existing plan. Use plan-create to create a new plan, plan-execute to run an approved plan, and plan-phases to add gates to a plan." | triggers="/deep-dive; do a deep dive; inspect each phase; look at this more carefully; check if we're missing anything" | gates="phases-found=ABORT; phase-passes=ABORT; synthesis=ABORT" | rules="no-batch=MUST; concrete-fixes=MUST; horizons=MUST; user-approves-amendments=MUST; no-lgtm=MUST_NOT; check-siblings=SHOULD" | next="plan-execute; plan-create; prime-sweep" | install="cp -r skills/plan-deep-dive <runtime>/skills/plan-deep-dive" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=plan-evolve | visibility=public | protocol=no | profile=none | description="Evolve a target to its next version — treat what shipped as v1, plan the next iteration. The target can be a plan, a repo, a system, a document, a feature, or a skill. If a v1 plan artifact exists, evolve it; if not, the current state of the target IS v1. Trigger: 'what would v2 look like', 'evolve this', 'what's next for this', 'next iteration of this', 'plan the next version'. Use plan-deep-dive to inspect the current state, plan-execute to run the new plan, and plan-cleanup to remove artifacts after execution." | triggers="what would v2 look like; evolve this; what's next for this; next iteration of this; plan the next version" | gates="" | rules="" | next="plan-deep-dive; insight-critique; plan-execute" | install="cp -r skills/plan-evolve <runtime>/skills/plan-evolve" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=plan-execute | visibility=public | protocol=yes | profile=exec | description="Apply the last approved plan exactly. Trigger when the user runs /execute or says 'execute the plan', 'implement this', 'do it', or 'go ahead' after a plan has been approved. Surface judgment calls — do not make them silently. Not /plan-create (designs the plan first) or /plan-deep-dive (inspects a plan without running it) — plan-execute runs an already-approved plan." | triggers="/execute; execute the plan; implement this; do it; go ahead" | gates="plan-found=ABORT; plan-valid=ABORT" | rules="exact-plan=MUST; gate-suite-before-commit=SHOULD; stop-on-drift=MUST; surface-judgment=MUST; no-add-features=MUST_NOT; report-progress-on-halt=MUST; terminal-decl=MUST" | next="verify; insight-retro; plan-cleanup" | install="cp -r skills/plan-execute <runtime>/skills/plan-execute" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=plan-phases | visibility=public | protocol=yes | profile=exec | description="Restructure an existing plan into phases with /verify gates after each phase and critical steps. Trigger when the user runs /phase-plan or asks to 'add phases to this plan', 'gate this plan', 'restructure the plan', or 'add checkpoints'. Use plan-create for new plans and plan-deep-dive for inspection without restructuring." | triggers="/phase-plan; add phases to this plan; gate this plan; restructure the plan; add checkpoints" | gates="plan-found=ABORT; phase-quality=ABORT; gate-coverage=ABORT; final=ABORT" | rules="preserve-content=MUST; preserve-intent=MUST; same-format=MUST; no-scope-add=MUST_NOT; no-ceremonial-gates=MUST_NOT; gate-after-phase=MUST; gate-after-risky=MUST; gate-cross-package=MUST; split-large-phases=SHOULD" | next="plan-execute; plan-deep-dive" | install="cp -r skills/plan-phases <runtime>/skills/plan-phases" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=prime-expand | visibility=public | protocol=yes | profile=exec | description="Expand a vague gap into concrete questions + named source candidates via a delegated sub-agent — caller sees only the proposed pair for confirm/edit/refuse, never the expansion reasoning. Trigger /prime-expand, 'expand on this', or auto-fire on handoff receipt with a thin brief. (Not for ambient 'I need to know X' phrasing — that would collide with /investigate.) Single sub-agent, single turn, ≤3 candidate-source spot-checks only. Pairs with /prime-fetch (single noisy tool call) and /prime-sweep (large source-surface investigation)." | triggers="/prime-expand; expand on this" | gates="cop=WARN; seed-vague=ABORT; decision-made=WARN" | rules="vague-seed-only=MUST; no-investigation=MUST_NOT; one-sub-agent=MUST; scan-cap=MUST; no-heavy-tools=MUST_NOT; depth-one=MUST_NOT; only-emit-pair=MUST; refusal-format=MUST; delegate-always=MUST; no-pow-needed=MUST_NOT; family-invariant=MUST" | next="prime-fetch; prime-sweep; plan-create" | install="cp -r skills/prime-expand <runtime>/skills/prime-expand" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=prime-fetch | visibility=public | protocol=yes | profile=exec | description="Run a noisy data-fetching tool call (Grep, Glob, WebFetch, MCP search) on the caller's behalf in a sub-agent's context — only the filtered, proof-of-work-verified digest enters the caller's window. Trigger /prime-fetch, or when a planned tool call will return mostly noise. Single sub-agent, single wave, read-only tool calls only. Pairs with /prime-expand (clarify intent first) and /prime-sweep (multi-source investigation)." | triggers="/prime-fetch" | gates="cop=WARN; read-only=ABORT" | rules="read-only-tool=MUST; single-call-only=MUST_NOT; dump-stays-internal=MUST; depth-one=MUST_NOT; emit-digest-only=MUST; tool-issued-verify=MUST; drop-unverifiable=MUST; data-not-directive=MUST; delegate-always=MUST; proof-of-work-required=MUST; single-wave=MUST; family-invariant=MUST" | next="prime-sweep; prime-expand" | install="cp -r skills/prime-fetch <runtime>/skills/prime-fetch" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=prime-sweep | visibility=public | protocol=yes | profile=exec | description="Prime the calling agent with high-signal context from large source surfaces (multiple files, packages, folders) via parallel delegated sub-agents. Sub-agents absorb the noise; only digested findings + source:line pointers enter the caller's context. Trigger /prime-sweep, chained from /prime-expand when sources are too large, or auto-fire on handoff receipt with listed sources. Iterative with cap 3 / log 4-6 / ask 7 / max 8 waves total. Pairs with /prime-expand (clarify intent first) and /prime-fetch (single noisy tool call)." | triggers="/prime-sweep" | gates="cop=WARN; has-sources=ABORT; wave-cap=ABORT" | rules="large-surface-only=MUST; not-execution=MUST_NOT; pow-contract=MUST; pointers-grounded=MUST; max-three=MUST_NOT; depth-one=MUST_NOT; tool-issued-verify=MUST; drop-unverifiable=MUST; lead-recomputes=MUST; inline-only=MUST; data-not-directive=MUST; decay-pointers=MUST; wave-counter-location=MUST; nested-rejection=MUST; abort-definition=MUST; delegate-source-reads=MUST; family-invariant=MUST" | next="prime-expand; plan-create" | install="cp -r skills/prime-sweep <runtime>/skills/prime-sweep" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=reflect | visibility=public | protocol=no | profile=none | description="Lightweight cognitive pause — surface assumptions, uncertainty, and what you'd do differently. No gate, no enforcement, no artifacts required. Trigger when the user runs /reflect or wants to step back and think before continuing. Not /verify (formal gate) or /ask-gate (question triage) — reflect is freeform thinking with no gate." | triggers="/reflect; step back and think before continuing" | gates="" | rules="" | next="verify; plan-create" | install="cp -r skills/reflect <runtime>/skills/reflect" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=self-improve | visibility=public | protocol=yes | profile=exec | description="The Self-Improvement Protocol (SIP). After a participating skill runs, detect concrete signals that the skill itself could be better — ambiguous instructions, an uncovered edge case, a misfired rule, a stale cross-reference, a user correction — and propose a specific diff to it, surfaced for approval and never auto-applied. Conservative by default: silent unless a ready, blocking, or recurring fix exists. Trigger via /self-improve, or automatically when a self-improvable skill completes. Not /insight-skill-gap (deliberate batch scan for new/updated skills) or /insight-retro (post-implementation review) — SIP is the in-the-moment, per-skill detector." | triggers="/self-improve; /self-improve [skill]" | gates="conservative-bar=SKIP" | rules="per-run-detector=MUST; concrete-diff=MUST; delegate-new-skill=SHOULD; no-auto-apply=MUST_NOT; dedup=MUST; conservative=MUST; depth-guard=MUST; no-reentry=MUST_NOT; surface-through-ask-gate=SHOULD" | next="ask-gate; insight-skill-gap; new-skill-creator" | install="cp -r skills/self-improve <runtime>/skills/self-improve" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=skills-help | visibility=public | protocol=no | profile=none | description="The skills library menu — every skill grouped by family, each with a one-line description and a dual-doc/single-doc marker; pass a family name to drill into one family in full detail. Trigger with /skills-help, 'list my skills', 'which skill for X', 'skills menu', 'what skills do I have'. Not /new-skill-creator (which scaffolds a new skill)." | triggers="/skills-help; /skills-help {family}; list my skills; which skill for X; skills menu; what skills do I have" | gates="" | rules="" | next="new-skill-creator; insight-skill-gap" | install="cp -r skills/skills-help <runtime>/skills/skills-help" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=verify | visibility=public | protocol=yes | profile=exec | description="Formal phase gate — checks intent, plan, and execution artifacts for drift. Requires the intent and execution artifacts (the plan is optional; an absent plan short-circuits to a plan-not-found verdict). Produces structured output. Trigger when the user runs /verify or needs to decide whether to proceed to the next phase. Not /double-check (quick re-check of one claim), /reflect (informal thinking, no gate), or /insight-critique (advisory output review) — verify is the formal gate against intent, plan, and execution." | triggers="/verify" | gates="intent=ABORT; execution=ABORT" | rules="plan-absent=MUST; route-investigate=SHOULD; route-replan=SHOULD; route-sync=SHOULD" | next="github-sync; plan-create; investigate" | install="cp -r skills/verify <runtime>/skills/verify" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=yon-read | visibility=public | protocol=no | profile=none | description="Read, interpret, or explain existing YON content. Trigger on any .yon file, YON snippet (lines with @TAG/.../... patterns), or when the user says 'read this YON', 'what does this YON mean', 'explain this @DOC/@RULE/@STEP', 'summarize this YON', 'interpret this record'. Do NOT trigger for generic format questions ('what is YON?') with no YON content present — and do not trigger when the user wants to *write* YON (use yon-write)." | triggers="read this YON; what does this YON mean; explain this @DOC/@RULE/@STEP; summarize this YON; interpret this record" | gates="" | rules="" | next="yon-write; double-check" | install="cp -r skills/yon-read <runtime>/skills/yon-read" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
@META id=yon-write | visibility=public | protocol=no | profile=none | description="YON Writing & Compilation Mode. Use when creating, generating, converting, or writing YON content. Triggers on: 'write YON', 'convert to YON', 'create a .yon file', 'encode this as YON', 'YON format', or any request where the expected output is YON records. Also triggers when unstructured content should be structured into YON even without explicit keyword — e.g., working in a YON project. Use yon-read instead when reading, interpreting, explaining, or summarizing existing YON." | triggers="write YON; convert to YON; create a .yon file; encode this as YON; YON format" | gates="" | rules="" | next="yon-read; double-check; github-sync" | install="cp -r skills/yon-write <runtime>/skills/yon-write" | license="Apache-2.0" | src="github.com/allemaar/open-skills"
