node_modules/
.DS_Store
*.log

# Stray agent-runtime / machine-local config must never ship inside a skill
# (a leaked skills/<name>/.claude/settings.json carried private machine paths once).
skills/*/.claude/
skills/*/.codex/
skills/*/.agents/
**/settings.local.json

# Repo-root agent-runtime dirs (Claude Code recreates .claude/worktrees on worktree ops).
# Local-only, never tracked — same leak class as the nested guard above.
/.claude/
/.codex/
/.agents/
